    # FORCE CLOSE / EMERGENCY CLOSE
    # ═══════════════════════════════════════════════════════════════════════


    def force_close_position(self, symbol: str,
                              side: Optional[str] = None,
                              contracts: Optional[float] = None) -> bool:
        """
        Принудительно закрывает позицию рыночным ордером.


        ФИКС (главный баг): использует positionSide из _market_close_params()
        В Hedge Mode без positionSide ордер ОТКРЫВАЛ новую позицию вместо закрытия.


        side и contracts можно передать явно (если известны) или
        они будут получены с биржи автоматически.
        """
        logger.critical(f"[FORCE CLOSE] Initiating for {symbol}")


        # Получаем данные позиции если не переданы явно
        if side is None or contracts is None:
            pos = self._fetch_open_position(symbol)
            if not pos:
                logger.warning(f"[FORCE CLOSE] No open position found for {symbol}")
                return False
            side      = str(pos.get('side', 'long'))
            contracts = float(pos.get('contracts', 0))


        if contracts <= 0:
            logger.warning(f"[FORCE CLOSE] Contracts = 0 for {symbol}, nothing to close")
            return False


        close_side, params = self._market_close_params(side)


        logger.critical(
            f"[FORCE CLOSE] {symbol} | {side.upper()} | "
            f"{contracts} contracts | close_side={close_side} | "
            f"positionSide={params['positionSide']}"
        )


        try:
            order = self.exchange.create_order(
                symbol = symbol,
                type   = 'market',
                side   = close_side,
                amount = contracts,
                params = params
            )


            if order:
                logger.critical(f"[FORCE CLOSE] SUCCESS: {symbol}")
                # Чистим все ордера и tracking
                self.cancel_all_orders(symbol)
                self.reset_emergency_state(symbol)
                self.notifier.send(
                    f"<b>FORCE CLOSE EXECUTED</b>\n"
                    f"Symbol: {symbol}\n"
                    f"Size: {contracts}\n"
                    f"Reason: SL recreation failed",
                    urgent=True
                )
                return True


            logger.error(f"[FORCE CLOSE] Order returned None for {symbol}")
            return False


        except Exception as e:
            logger.error(f"[FORCE CLOSE] Exception for {symbol}: {e}")
            return False


    def emergency_close(self, symbol: str,
                         side: Optional[str] = None,
                         contracts: Optional[float] = None,
                         reason: str = 'Emergency') -> bool:
        """
        Emergency close с circuit breaker.


        Если за MAX_EMERGENCY_ATTEMPTS попыток закрыть не удалось —
        отправляет MANUAL INTERVENTION ALERT и прекращает попытки.
        Это предотвращает бесконечный цикл из логов.


        Возвращает True если закрыто успешно.
        """
        attempt = self._emergency_attempts.get(symbol, 0) + 1
        self._emergency_attempts[symbol] = attempt


        logger.critical(
            f"[EMERGENCY] {symbol} | Attempt {attempt}/{MAX_EMERGENCY_ATTEMPTS} | {reason}"
        )


        if attempt > MAX_EMERGENCY_ATTEMPTS:
            # Circuit breaker сработал — прекращаем попытки
            logger.critical(
                f"[EMERGENCY] CIRCUIT BREAKER: {symbol} — "
                f"{MAX_EMERGENCY_ATTEMPTS} attempts failed. MANUAL ACTION REQUIRED."
            )
            self.notifier.send(
                f"🚨 <b>CRITICAL: MANUAL INTERVENTION REQUIRED</b>\n"
                f"Symbol: {symbol}\n"
                f"Emergency close failed {MAX_EMERGENCY_ATTEMPTS}x\n"
                f"Reason: {reason}\n"
                f"<b>CLOSE MANUALLY ON EXCHANGE!</b>",
                urgent=True
            )
            # Убираем из tracking чтобы прекратить цикл мониторинга
            self.active_sl_orders.pop(symbol, None)
            self.active_tp_orders.pop(symbol, None)
            self._emergency_attempts.pop(symbol, None)
            return False


        # Попытка закрыть
        success = self.force_close_position(symbol, side=side, contracts=contracts)


        if success:
            self.reset_emergency_state(symbol)
            return True


        self.notifier.send(
            f"<b>EMERGENCY EXIT</b>\n"
            f"Symbol: {symbol}\n"
            f"Attempt: {attempt}/{MAX_EMERGENCY_ATTEMPTS}\n"
            f"Reason: {reason}",
            urgent=True
        )
        return False


    def reset_emergency_state(self, symbol: str):
        """Сбрасывает счётчик emergency попыток после успешного закрытия."""
        if symbol in self._emergency_attempts:
            logger.info(f"[EMERGENCY] Reset state for {symbol}")
            del self._emergency_attempts[symbol]



