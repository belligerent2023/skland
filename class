    def update_sl(self, symbol: str, side: str,
                  new_size: float, new_price: float,
                  label: str = 'SL') -> Optional[str]:
        """
        Безопасное обновление SL: сначала НОВЫЙ ордер, потом отмена старого.
        Позиция никогда не остаётся без защиты.


        Используется для:
        - Перевода в безубыток (после TP1)
        - Переноса SL на TP1 уровень (после TP2)
        - Трейлинга
        """
        old_order_data = self.active_sl_orders.get(symbol)


        # 1. Выставляем НОВЫЙ SL
        new_id = self._place_sl_with_retry(symbol, side, new_size, new_price)


        if new_id:
            # 2. Обновляем tracking СРАЗУ — позиция уже под защитой
            self.active_sl_orders[symbol] = {
                'order_id':  new_id,
                'type':      'updated_sl',
                'price':     new_price,
                'side':      side,
                'timestamp': datetime.now()
            }
            logger.info(f"[{label}] Updated for {symbol}: ${new_price:.6f} size={new_size}")


            # 3. Отменяем СТАРЫЙ ордер (уже после того как новый активен)
            if old_order_data:
                try:
                    self.exchange.cancel_order(old_order_data['order_id'], symbol)
                    logger.info(f"[{label}] Old SL cancelled: {old_order_data['order_id']}")
                except Exception as e:
                    # Не критично — старый мог уже сработать или истечь
                    logger.warning(
                        f"[{label}] Could not cancel old SL "
                        f"{old_order_data['order_id']}: {e} — ignoring"
                    )
        else:
            logger.error(f"[{label}] FAILED to place new SL for {symbol}!")
            self.notifier.send(
                f"<b>SL UPDATE FAILED</b>\n"
                f"Symbol: {symbol}\n"
                f"Label: {label}\n"
                f"Old SL still active (if it was)",
                urgent=True
            )


        return new_id  # None если не удалось


    def move_sl_to_breakeven(self, symbol: str, side: str,
                              entry_price: float,
                              new_size: float) -> Optional[str]:
        """
        Переводит SL в безубыток (entry + fee buffer).
        Вызывается когда TP1 заполнился.
        """
        # +0.2% buffer: покрывает taker fee 0.045% x2 + funding
        be_price = entry_price * 1.002 if side.lower() == 'long' else entry_price * 0.998


        logger.info(f"[BE] Moving SL to breakeven for {symbol}")
        logger.info(f"   Entry: ${entry_price:.6f} -> BE: ${be_price:.6f}")
        logger.info(f"   Remaining size: {new_size}")


        new_id = self.update_sl(symbol, side, new_size, be_price, label='BE')
        if new_id:
            self.notifier.send(
                f"<b>SL -> BREAKEVEN</b>\n"
                f"Symbol: {symbol}\n"
                f"Entry: ${entry_price:.4f}\n"
                f"BE Price: ${be_price:.4f}\n"
                f"Remaining: {new_size} contracts\n"
                f"Loss protected!",
                urgent=False
            )
        return new_id


    def move_sl_to_tp1(self, symbol: str, side: str,
                        tp1_price: float,
                        new_size: float) -> Optional[str]:
        """
        Переносит SL на уровень TP1 (-0.5% буфер).
        Вызывается когда TP2 заполнился.
        """
        sl_price = tp1_price * 0.995 if side.lower() == 'long' else tp1_price * 1.005


        logger.info(f"[SL-TP1] Moving SL to TP1 level for {symbol}")
        logger.info(f"   TP1: ${tp1_price:.6f} -> SL: ${sl_price:.6f}")


        new_id = self.update_sl(symbol, side, new_size, sl_price, label='SL-TP1')
        if new_id:
            self.notifier.send(
                f"<b>SL -> TP1 LEVEL</b>\n"
                f"Symbol: {symbol}\n"
                f"SL Price: ${sl_price:.4f}\n"
                f"Profit locked!",
                urgent=False
            )
        return new_id


    def update_sl_size(self, symbol: str, side: str,
                       new_size: float) -> Optional[str]:
        """
        Обновляет размер существующего SL (после частичного TP).
        Пересоздаёт ордер с той же ценой, новым размером.
        """
        if symbol not in self.active_sl_orders:
            logger.warning(f"[SL] No active SL for {symbol}, cannot resize")
            return None


        current_sl_price = self.active_sl_orders[symbol]['price']
        return self.update_sl(symbol, side, new_size, current_sl_price, label='SL-RESIZE')



