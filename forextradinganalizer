async def _send_recent_trades(update=None, query=None, bot=None, edit: bool = False, limit: int = 10):
    """Build last N closed trades message from journal."""
    try:
        ws_name = bot.trade_journal._ensure_monthly_sheet()
        if not ws_name:
            text = "❌ Cannot read journal"
        else:
            ws = bot.trade_journal.workbook[ws_name]
            rows = []
            for row in range(ws.max_row, 1, -1):
                outcome = ws.cell(row=row, column=4).value or ""
                if outcome in ("OPEN", "") or "WEEK" in str(outcome).upper():
                    continue
                date    = ws.cell(row=row, column=1).value or ""
                symbol  = ws.cell(row=row, column=2).value or ""
                direction = ws.cell(row=row, column=3).value or ""
                result  = ws.cell(row=row, column=5).value or ""
                rows.append((date, symbol, direction, outcome, result))
                if len(rows) >= limit:
                    break

            if not rows:
                text = "📋 No closed trades this month yet"
            else:
                text = f"📋 <b>LAST {len(rows)} TRADES (this month)</b>\n\n"
                text += "<code>"
                text += f"{'Date':<12} {'Pair':<8} {'Dir':<5} {'Out':<5} {'Result':>8}\n"
                text += "-" * 42 + "\n"
                for date, symbol, direction, outcome, result in rows:
                    emoji = "✅" if str(outcome).startswith("TP") else "❌" if outcome == "SL" else "➖"
                    text += f"{str(date):<12} {symbol:<8} {direction:<5} {emoji:<5} {str(result):>8}\n"
                text += "</code>"

        if edit and query:
            await query.edit_message_text(text, parse_mode='HTML')
        elif update:
            await update.message.reply_text(text, parse_mode='HTML')

    except Exception as e:
        logger.error(f"Recent trades error: {e}")
        msg = f"❌ Error reading journal: {e}"
        if edit and query:
            await query.edit_message_text(msg)
        elif update:
            await update.message.reply_text(msg)


