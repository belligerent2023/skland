          LONG:  RSI > 72 → немедленный False
        """
        try:
            if len(df_15m) < 20:
                return False, 0.0

            # ─── 1. Свечной анализ (последние 3 свечи) ───────────────
            last_3       = df_15m.iloc[-3:].copy()
            body_size    = (last_3['close'] - last_3['open']).abs().mean()
            candle_range = (last_3['high'] - last_3['low']).mean()

            if direction == 'LONG':
                direction_count = (last_3['close'] > last_3['open']).sum()
                if direction_count < 2:
                    return False, 0.0
            else:  # SHORT
                direction_count = (last_3['close'] < last_3['open']).sum()
                if direction_count < 2:
                    return False, 0.0

            # Body > 40% range (не пины, реальный импульс)
            if candle_range > 0 and body_size < candle_range * 0.4:
                return False, 0.0

            # ─── 2. RSI M15 — синхронизировано с v3.0 ────────────────
            rsi = float(self.calculate_rsi(df_15m, 14).iloc[-1])

            if direction == 'LONG':
                # ✅ Допустимая зона: RSI 38–70
                # RSI < 38 → слишком низко, нет бычьего импульса ещё
                # RSI > 72 → перекуплен, поздний вход
                if rsi < 38:
                    return False, 0.0
                if rsi > 72:
                    return False, 0.0
            else:  # SHORT
                # ✅ Допустимая зона: RSI 30–62
                # RSI < 28 → HARD BLOCK: momentum exhausted (кейс EURUSD RSI=18.4)
                # RSI > 62 → импульс вниз ещё не начался
                if rsi < 28:
                    logger.warning(
                        f"[MOMENTUM] ⛔ M15 RSI HARD BLOCK SHORT: RSI={rsi:.1f} < 28 "
                        f"(momentum exhausted)"
                    )
                    return False, 0.0
                if rsi > 62:
                    return False, 0.0

            # ─── 3. Объём ≥ 1.2x среднего ────────────────────────────
            current_volume = df_15m['tick_volume'].iloc[-1]
            avg_volume     = df_15m['tick_volume'].iloc[-20:-1].mean()
            volume_ratio   = current_volume / avg_volume if avg_volume > 0 else 1.0

            if volume_ratio < 1.2:
                return False, 0.0

            # ─── Momentum score (0–100) ───────────────────────────────
            momentum_score = min(100, direction_count * 25 + volume_ratio * 15)

            return True, momentum_score

        except Exception as e:
            logger.error(f"Momentum check error: {e}")
