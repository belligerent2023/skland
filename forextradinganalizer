    def execute_manual_signal(self, signal: Dict):
        """
        Execute manual signal from Telegram/AFX.
        - LIMIT order if price not yet at entry
        - TP = max available TP
        - Saves all TP levels for SL trailing
        """
        try:
            symbol        = signal['symbol']
            broker_symbol = self._convert_to_broker_symbol(symbol)
            direction     = signal['direction']
            entry         = signal['entry']
            sl            = signal['sl']

            logger.info(f"[EXECUTE MANUAL] {symbol} ({broker_symbol}) {direction} @ {entry:.5f}")

            # ── 1. Age check (max 2 hours) ──
            message_time = signal.get('message_time')
            if message_time:
                age_seconds = (datetime.utcnow() - message_time).total_seconds()
                age_minutes = age_seconds / 60
                if age_seconds > 7200:
                    logger.warning(f"[SKIP] Signal too old: {age_minutes:.0f} min")
                    self.notifier.send(
                        f"⏰ SIGNAL SKIPPED (TOO OLD)\n\n"
                        f"Symbol: {symbol}\nDirection: {direction}\n"
                        f"Age: {age_minutes:.0f} min (max 120)\n"
                        f"Entry: {entry:.5f}",
                        urgent=False
                    )
                    return
                logger.info(f"  Signal age: {age_minutes:.1f} min — OK")

            # ── 2. Validate SL ──
            if not self.risk_manager.validate_sl_distance(entry, sl, symbol):
                logger.error(f"[REJECT] Invalid SL distance for {symbol}")
                self.notifier.send(
                    f"❌ SIGNAL REJECTED\n\nSymbol: {symbol}\nReason: Invalid SL distance",
                    urgent=False
                )
                return

            # ── 3. Calculate lot ──
            balance = self.mt5.get_balance()
            lot     = self.risk_manager.calculate_lot_size(
                broker_symbol, entry, sl, balance, Config.RISK_PER_TRADE
            )

            if lot == 0:
                logger.error(f"[REJECT] Cannot calculate lot for {symbol}")
                self.notifier.send(
                    f"❌ SIGNAL REJECTED\n\nSymbol: {symbol}\nReason: Cannot calculate lot size",
                    urgent=False
                )
                return

            # ── 4. Select max TP ──
            all_tps = [
                t for t in [
                    signal.get('tp1'), signal.get('tp2'),
                    signal.get('tp3'), signal.get('tp4')
                ] if t is not None
            ]

            if all_tps:
                tp_final = max(all_tps) if direction == 'BUY' else min(all_tps)
            else:
                sl_distance = abs(entry - sl)
                tp_final = (
                    entry + sl_distance * Config.MIN_RR_RATIO
                    if direction == 'BUY'
                    else entry - sl_distance * Config.MIN_RR_RATIO
                )

            logger.info(f"  TPs: {all_tps} | Max TP: {tp_final:.5f}")

            # ── 5. Price deviation check ──
            tick          = self.mt5.get_tick(broker_symbol)
            current_price = tick['ask'] if direction == 'BUY' else tick['bid']

            df_15m = self.mt5.get_ohlcv(broker_symbol, Config.MAIN_TIMEFRAME, 50)
            try:
                h = df_15m['high']; l = df_15m['low']; c = df_15m['close']
                tr      = pd.concat([h - l, abs(h - c.shift()), abs(l - c.shift())], axis=1).max(axis=1)
                atr_val = float(tr.rolling(14).mean().iloc[-1])
            except Exception:
                atr_val = abs(entry - sl) * 0.5

            price_deviation      = abs(current_price - entry)
            max_allowed_deviation = atr_val * 0.5

            if price_deviation > max_allowed_deviation:
                logger.warning(
                    f"[SKIP] Price {current_price:.5f} too far from entry {entry:.5f} "
                    f"(deviation {price_deviation:.5f} > allowed {max_allowed_deviation:.5f})"
                )
                self.notifier.send(
                    f"⚠️ SIGNAL SKIPPED (PRICE MOVED)\n\n"
                    f"Symbol: {symbol}\nEntry zone: {entry:.5f}\n"
                    f"Current: {current_price:.5f}\n"
                    f"Deviation: {price_deviation:.5f} (max {max_allowed_deviation:.5f})",
                    urgent=False
                )
                return

            # ── 6. Market or Limit ──
            price_at_zone  = price_deviation <= atr_val * 0.1
            order_type_used = "MARKET" if price_at_zone else "LIMIT"

            if price_at_zone:
                ticket = self.mt5.open_trade(
                    symbol=broker_symbol, direction=direction,
                    lot=lot, sl=sl, tp=tp_final,
                    comment=f"MANUAL_{signal['source']}"
                )
            else:
                ticket = self.mt5.open_limit_order(
                    symbol=broker_symbol, direction=direction,
                    lot=lot, price=entry, sl=sl, tp=tp_final,
                    comment=f"LIMIT_{signal['source']}",
                    expiry_hours=48
                )

            if ticket:
                self.position_tracker.track_position(ticket, {
                    'symbol':    broker_symbol,
                    'direction': direction,
                    'entry':     entry,
                    'tp1':       signal.get('tp1'),
                    'tp2':       signal.get('tp2'),
                    'tp3':       signal.get('tp3'),
                    'tp4':       signal.get('tp4'),
                    'tp_final':  tp_final,
                    'sl':        sl,
                    'source':    signal.get('source', 'MANUAL'),
                })

                # 🆕 Journal: log open
                self.trade_journal.log_trade_open(
                    ticket=ticket, symbol=symbol,
                    direction=direction, entry=entry
                )

                tp_text = "\n".join(
                    f"TP{i}: {signal[f'tp{i}']:.5f}"
                    for i in range(1, 5)
                    if signal.get(f'tp{i}')
                )

                self.notifier.send(
                    f"✅ MANUAL TRADE ({order_type_used})\n\n"
                    f"Symbol: {symbol}\n"
                    f"Direction: {direction}\n"
                    f"{'Price' if order_type_used == 'LIMIT' else 'Entry'}: {entry:.5f}\n"
                    f"{tp_text}\n"
                    f"→ MT5 TP set to: {tp_final:.5f}\n"
                    f"SL: {sl:.5f}\n"
                    f"Lot: {lot:.2f}\n"
                    f"Ticket: #{ticket}\n"
                    f"Source: {signal['source']}",
                    urgent=True
                )
                logger.info(f"[OK] Manual {order_type_used}: #{ticket} {symbol} {direction}")
            else:
                logger.error(f"[FAILED] Could not open manual trade for {symbol}")
                self.notifier.send(
                    f"❌ TRADE FAILED\n\nSymbol: {symbol}\nDirection: {direction}\n"
                    f"Could not open position",
                    urgent=True
                )

        except Exception as e:
            logger.error(f"Execute manual signal error: {e}")

