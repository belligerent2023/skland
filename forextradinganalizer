            if trend_1h == 'BULLISH' and trend_15m in ['BULLISH', 'NEUTRAL']:
                score += 25
                signals.append("✅ BULLISH trend alignment")
                logger.info(f"  [+25] Bullish alignment")
            elif trend_1h == 'BEARISH' and trend_15m in ['BEARISH', 'NEUTRAL']:
                score += 25
                signals.append("✅ BEARISH trend alignment")
                logger.info(f"  [+25] Bearish alignment")
            else:
                warnings.append("⚠️ Trend conflict")
                logger.warning(f"  [-5] Trend conflict")
                score -= 5

            # ==================== MARKET REGIME ====================
            logger.info(f"\n[MARKET REGIME]")
            regime_1h = self.detect_market_regime(df_1h)
            logger.info(f"  H1 Regime: {regime_1h}")

            if regime_1h == 'TRENDING':
                score += 10
                signals.append("✅ H1 Strong Trend (ADX > 25)")
                logger.info(f"  [+10] Strong trend")
            elif regime_1h == 'RANGING':
                score += 5
                signals.append("✅ Consolidation - breakout setup")
                logger.info(f"  [+5] Consolidation")

            # ==================== ATR FILTER ====================
            logger.info(f"\n[VOLATILITY CHECK]")
            atr_pct = self.calculate_atr_pct(df_15m)
            logger.info(f"  ATR: {atr_pct*100:.3f}%")

            min_atr = 0.002 if symbol in ['GOLD', 'XAUUSD', 'XAGUSD'] else Config.MIN_ATR_PCT
            max_atr = Config.MAX_ATR_PCT

            if atr_pct < min_atr:
                warnings.append(f"⚠️ ATR too low: {atr_pct*100:.3f}%")
                logger.warning(f"  [BLOCK] ATR too low")
                return {
                    'score': 0,
                    'signal': 'NONE',
                    'reason': 'ATR too low',
                    'symbol': symbol
                }

            if atr_pct > max_atr:
                warnings.append(f"⚠️ ATR too high: {atr_pct*100:.3f}% (news?)")
                logger.warning(f"  [BLOCK] ATR too high")
                return {
                    'score': 0,
                    'signal': 'NONE',
                    'reason': 'ATR too high',
                    'symbol': symbol
                }

            score += 10
            logger.info(f"  [+10] ATR OK")

            # ==================== RSI CHECK ====================
            rsi = float(self.calculate_rsi(df_15m, 14).iloc[-1])
            logger.info(f"\n[RSI]")
            logger.info(f"  RSI: {rsi:.1f}")

            if 25 < rsi < 75:
                score += 5
                logger.info(f"  [+5] RSI neutral")
            else:
                warnings.append(f"⚠️ RSI extreme: {rsi:.1f}")
                logger.warning(f"  [-3] RSI extreme")
                score -= 3

            # ==================== CONFLICT DETECTION ====================
            logger.info(f"\n[SIGNAL QUALITY CHECK]")
            bullish_count = sum(1 for s in signals if 'BULL' in s.upper() or 'PWL' in s or 'bounce' in s.lower())
            bearish_count = sum(1 for s in signals if 'BEAR' in s.upper() or 'PWH' in s or 'rejection' in s.lower())

            logger.info(f"  Bullish factors: {bullish_count}")
            logger.info(f"  Bearish factors: {bearish_count}")

            # 🚫 HARD BLOCK: conflicting signals
            if abs(bullish_count - bearish_count) <= 1:
                warnings.append("⚠️ CONFLICTING SIGNALS - no clear direction")
                logger.warning(f"  [BLOCKED] Signal conflict detected")
                return {
                    'score': score,
                    'signal': 'NONE',
                    'reason': 'Conflicting signals - unclear direction',
                    'symbol': symbol,
                    'bullish_count': bullish_count,
                    'bearish_count': bearish_count
                }

            logger.info(f"  [OK] Clear direction: {'BULLISH' if bullish_count > bearish_count else 'BEARISH'}")

            # ==================== DETERMINE SIGNAL ====================
            logger.info(f"\n{'='*60}")
            logger.info(f"[FINAL SCORE] {score}")
            logger.info(f"[MIN REQUIRED] {Config.MIN_SCORE}")
            logger.info(f"{'='*60}")

            signal_type = 'NONE'

            if score >= Config.MIN_SCORE:
                # Determine direction based on clear majority
                if bullish_count > bearish_count:
                    if trend_1h in ['BULLISH', 'NEUTRAL']:
                        signal_type = 'LONG'
                    else:
                        logger.warning(f"  [CONFLICT] Bullish signals but bearish trend")
                        signal_type = 'WAIT'
                elif bearish_count > bullish_count:
                    if trend_1h in ['BEARISH', 'NEUTRAL']:
                        signal_type = 'SHORT'
                    else:
                        logger.warning(f"  [CONFLICT] Bearish signals but bullish trend")
                        signal_type = 'WAIT'
                else:
                    signal_type = 'WAIT'
            else:
                logger.warning(f"  [LOW SCORE] {score} < {Config.MIN_SCORE}")

            # ==================== 🆕 BOS + MOMENTUM CONFIRMATION ====================
            if signal_type in ['LONG', 'SHORT']:
                logger.info(f"\n{'='*60}")
                logger.info(f"[🔥 ENTRY CONFIRMATION] Checking BOS + Momentum...")
                logger.info(f"{'='*60}")
                
                # 🆕 ОБЯЗАТЕЛЬНАЯ ПРОВЕРКА BOS
                bos_confirmed, bos_msg = self.confirm_bos_entry(
                    df_15m, 
                    'LONG' if signal_type == 'LONG' else 'SHORT'
                )
                
                if not bos_confirmed:
                    logger.warning(f"[❌ BOS REJECT] {symbol}: {bos_msg}")
                    return {
                        'symbol': symbol,
                        'signal': 'NONE',
                        'score': score,
                        'entry_price': current_price,
                        'reason': f"No BOS confirmation: {bos_msg}",
                        'reasons': signals + [f"❌ No BOS: {bos_msg}"],
                        'warnings': warnings,
                        'atr_pct': atr_pct,
                        'trend_1h': trend_1h,
                        'trend_15m': trend_15m,
                        'rsi': rsi,
                        'session_info': session_info,
                        'volume_ratio': volume_ratio
                    }
                
                logger.info(f"[+15] ✅ {bos_msg}")
                signals.append(f"✅ BOS: {bos_msg}")
                score += 15  # Бонус за подтверждение
                
                # 🆕 ПРОВЕРКА MOMENTUM ПРЯМО СЕЙЧАС
                has_momentum, momentum_score = self.check_immediate_momentum(
                    df_15m, 
                    'LONG' if signal_type == 'LONG' else 'SHORT'
                )
                
                if not has_momentum:
                    logger.warning(f"[❌ MOMENTUM REJECT] {symbol}: No immediate momentum")
                    return {
                        'symbol': symbol,
                        'signal': 'NONE',
                        'score': score,
                        'entry_price': current_price,
                        'reason': "No immediate momentum",
                        'reasons': signals + ["❌ No immediate momentum"],
                        'warnings': warnings,
                        'atr_pct': atr_pct,
                        'trend_1h': trend_1h,
                        'trend_15m': trend_15m,
                        'rsi': rsi,
                        'session_info': session_info,
                        'volume_ratio': volume_ratio
                    }
                
                momentum_bonus = int(momentum_score * 0.2)
                logger.info(f"[+{momentum_bonus}] ✅ Strong Momentum: {momentum_score:.0f}/100")
                signals.append(f"✅ Momentum: {momentum_score:.0f}/100")
                score += momentum_bonus  # До +20 баллов
                
                logger.info(f"\n[✅ FINAL SCORE AFTER CONFIRMATION] {score}")
                logger.info(f"[✅ SIGNAL CONFIRMED] {signal_type}")

            logger.info(f"[SIGNAL] {signal_type}")

            return {
                'score': score,
                'signal': signal_type,
                'entry_price': current_price,
                'reasons': signals,
                'warnings': warnings,
                'atr_pct': atr_pct,
                'trend_1h': trend_1h,
                'trend_15m': trend_15m,
                'rsi': rsi,
                'symbol': symbol,
                'session_info': session_info,
                'volume_ratio': volume_ratio,
                'bullish_count': bullish_count,
                'bearish_count': bearish_count,
                'weekly_levels': weekly_levels,
                'stb_manipulation': stb_manip,
                'inducement': inducement
            }

        except Exception as e:
            logger.error(f"[SMC ANALYSIS ERROR] {e}")
            import traceback
            traceback.print_exc()
            return {
                'score': 0,
                'signal': 'NONE',
                'reason': str(e),
                'reasons': [],
                'warnings': [],
                'symbol': symbol
            }

# ==================== LEVEL RETEST STRATEGY ====================
class LevelRetestAnalyzer:
    """
    Strategy: Support/Resistance Flip + Level Retest

    Логика:
    1. Ключевые горизонтальные уровни по swing highs/lows на H1
    2. Уровень валидный = 2+ касания в пределах tolerance
    3. Пробой уровня (2+ свечи закрылись по ту сторону)
    4. Ретест (цена вернулась к уровню в пределах ATR)
    5. Свеча отторжения (pin bar, engulfing, strong candle)
    6. Вход: от уровня в направлении пробоя
    7. SL: за уровнем + буфер ATR × 0.5
    8. TP: следующий ключевой уровень
    """

    def __init__(self):
        self.mt5 = None

    # ──────────────────────────────────────────────────
    # ATR HELPER
    # ──────────────────────────────────────────────────

    def calculate_atr(self, df: pd.DataFrame) -> float:
        try:
            tr1 = df['high'] - df['low']
            tr2 = abs(df['high'] - df['close'].shift())
            tr3 = abs(df['low'] - df['close'].shift())
            tr  = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
            return float(tr.rolling(14).mean().iloc[-1])
        except:
            return 0.0

    # ──────────────────────────────────────────────────
    # KEY LEVELS DETECTION
    # ──────────────────────────────────────────────────

    def detect_key_levels(
        self, df: pd.DataFrame,
        lookback: int = 100,
        tolerance_pct: float = 0.0015
    ) -> List[Dict]:
        """
        Ключевые горизонтальные уровни по кластеризации свинг-хаев/лоев.
        Уровень валиден при >= 2 касаниях.
        """
        try:
            if len(df) < lookback:
                return []

            recent        = df.iloc[-lookback:].copy().reset_index(drop=True)
            current_price = float(df['close'].iloc[-1])
            raw_levels    = []

            for i in range(2, len(recent) - 2):
                # Swing High
                if (recent.iloc[i]['high'] > recent.iloc[i-1]['high'] and
                        recent.iloc[i]['high'] > recent.iloc[i-2]['high'] and
                        recent.iloc[i]['high'] > recent.iloc[i+1]['high'] and
                        recent.iloc[i]['high'] > recent.iloc[i+2]['high']):
                    raw_levels.append({
                        'price': float(recent.iloc[i]['high']),
                        'kind': 'high', 'idx': i
                    })

                # Swing Low
                if (recent.iloc[i]['low'] < recent.iloc[i-1]['low'] and
                        recent.iloc[i]['low'] < recent.iloc[i-2]['low'] and
                        recent.iloc[i]['low'] < recent.iloc[i+1]['low'] and
                        recent.iloc[i]['low'] < recent.iloc[i+2]['low']):
                    raw_levels.append({
                        'price': float(recent.iloc[i]['low']),
                        'kind': 'low', 'idx': i
                    })

            # ── Кластеризация близких уровней ──
            used       = set()
            key_levels = []

            for i, lv in enumerate(raw_levels):
                if i in used:
                    continue
                cluster = [lv]
                for j, other in enumerate(raw_levels):
                    if j != i and j not in used:
                        if abs(lv['price'] - other['price']) / lv['price'] < tolerance_pct:
                            cluster.append(other)
                            used.add(j)
                used.add(i)

                if len(cluster) >= 2:
                    avg_price = sum(c['price'] for c in cluster) / len(cluster)
                    key_levels.append({
                        'price':        avg_price,
                        'touches':      len(cluster),
                        'strength':     'STRONG' if len(cluster) >= 3 else 'MODERATE',
                        'distance_pct': abs(avg_price - current_price) / current_price * 100,
                    })

            key_levels.sort(key=lambda x: x['distance_pct'])

            logger.info(f"[KEY LEVELS] Found {len(key_levels)} levels")
            for lv in key_levels[:5]:
                logger.info(
                    f"  {lv['price']:.5f} | {lv['touches']} touches | "
                    f"{lv['strength']} | {lv['distance_pct']:.2f}% away"
                )

            return key_levels[:10]

        except Exception as e:
            logger.error(f"detect_key_levels error: {e}")
            return []

    # ──────────────────────────────────────────────────
    # BREAKOUT DETECTION
    # ──────────────────────────────────────────────────

    def detect_level_breakout(
        self, df: pd.DataFrame,
        level_price: float,
        confirmation_candles: int = 2
    ) -> Optional[str]:
        """
        Возвращает:
        - 'BROKE_ABOVE' → уровень пробит вверх (стал поддержкой)
        - 'BROKE_BELOW' → уровень пробит вниз (стал сопротивлением)
        - None           → пробоя не было
        """
        try:
            if len(df) < 25:
                return None

            breakout_window = df.iloc[-20:-3]   # окно пробоя
            current_price   = float(df['close'].iloc[-1])

            # Пробой ВВЕРХ + возврат к уровню
            closed_above   = (breakout_window['close'] > level_price * 1.0003).sum()
            came_back_down = current_price <= level_price * 1.003

            if closed_above >= confirmation_candles and came_back_down:
                logger.info(
                    f"  [BROKE_ABOVE] {level_price:.5f} | "
                    f"{closed_above} candles above | Price returned to retest"
                )
                return 'BROKE_ABOVE'

            # Пробой ВНИЗ + возврат к уровню
            closed_below  = (breakout_window['close'] < level_price * 0.9997).sum()
            came_back_up  = current_price >= level_price * 0.997

            if closed_below >= confirmation_candles and came_back_up:
                logger.info(
                    f"  [BROKE_BELOW] {level_price:.5f} | "
                    f"{closed_below} candles below | Price returned to retest"
                )
                return 'BROKE_BELOW'

            return None

        except Exception as e:
            logger.error(f"detect_level_breakout error: {e}")
            return None

    # ──────────────────────────────────────────────────
    # REJECTION CANDLE
    # ──────────────────────────────────────────────────

    def detect_rejection_candle(
        self, df: pd.DataFrame, direction: str
    ) -> Tuple[bool, str]:
        """
        Паттерны:
        - Pin Bar    (длинный wick, маленькое тело)
        - Engulfing  (поглощение предыдущей свечи)
        - Strong Candle (тело > 60% range)
        direction: 'BEARISH' или 'BULLISH'
        """
        try:
            if len(df) < 3:
                return False, "Not enough data"

            c = df.iloc[-1]
            p = df.iloc[-2]

            body        = abs(c['close'] - c['open'])
            total_range = c['high'] - c['low']

            if total_range < 0.000001:
                return False, "Zero range"

            upper_wick = c['high'] - max(c['close'], c['open'])
            lower_wick = min(c['close'], c['open']) - c['low']

            if direction == 'BEARISH':
                if upper_wick > body * 1.8 and c['close'] < c['open']:
                    return True, f"🎯 Bearish Pin Bar (wick {upper_wick / total_range * 100:.0f}%)"
                if c['open'] > p['close'] and c['close'] < p['open'] and c['close'] < c['open']:
                    return True, "🎯 Bearish Engulfing"
                if c['close'] < c['open'] and body > total_range * 0.60:
                    return True, f"✅ Strong Bearish ({body / total_range * 100:.0f}% body)"

            else:   # BULLISH
                if lower_wick > body * 1.8 and c['close'] > c['open']:
                    return True, f"🎯 Bullish Pin Bar (wick {lower_wick / total_range * 100:.0f}%)"
                if c['open'] < p['close'] and c['close'] > p['open'] and c['close'] > c['open']:
                    return True, "🎯 Bullish Engulfing"
                if c['close'] > c['open'] and body > total_range * 0.60:
                    return True, f"✅ Strong Bullish ({body / total_range * 100:.0f}% body)"

            return False, "No rejection candle yet"

        except Exception as e:
            logger.error(f"detect_rejection_candle error: {e}")
            return False, str(e)

    # ──────────────────────────────────────────────────
    # NEXT TARGET (TP)
    # ──────────────────────────────────────────────────

    def find_next_target(
        self, key_levels: List[Dict],
        current_price: float,
        direction: str
    ) -> Optional[float]:
        """Найти следующий ключевой уровень как цель (TP)"""
        try:
            if direction == 'SHORT':
                candidates = [lv['price'] for lv in key_levels if lv['price'] < current_price * 0.998]
                return max(candidates) if candidates else None
            else:
                candidates = [lv['price'] for lv in key_levels if lv['price'] > current_price * 1.002]
                return min(candidates) if candidates else None
        except:
            return None

    # ──────────────────────────────────────────────────
    # MAIN ANALYZE
    # ──────────────────────────────────────────────────

    def analyze(self, symbol: str, broker_symbol: str, mt5_connector) -> Dict:
        """Главный метод: анализ по стратегии Level Retest"""
        try:
            self.mt5 = mt5_connector

            session_info = SessionFilter.get_current_session()
            if Config.ONLY_ACTIVE_SESSIONS and not session_info['active']:
                return {
                    'score': 0, 'signal': 'NONE', 'symbol': symbol,
                    'strategy': 'LEVEL_RETEST',
                    'reason': f"Inactive session: {session_info['session']}",
                }

            df_h1  = self.mt5.get_ohlcv(broker_symbol, "H1",  150)
            df_m15 = self.mt5.get_ohlcv(broker_symbol, "M15", 100)

            if df_h1.empty or df_m15.empty:
                return {
                    'score': 0, 'signal': 'NONE',
                    'reason': 'No data', 'symbol': symbol,
                }

            current_price = float(df_m15['close'].iloc[-1])
            atr_h1        = self.calculate_atr(df_h1)
            score         = 0
            signals       = []

            logger.info(f"\n{'=' * 60}")
            logger.info(f"[LEVEL RETEST] {symbol} @ {current_price:.5f} | ATR={atr_h1:.5f}")
            logger.info(f"{'=' * 60}")

            # ── STEP 1: Ключевые уровни ──
            key_levels = self.detect_key_levels(df_h1, lookback=100)
            if not key_levels:
                return {
                    'score': 0, 'signal': 'NONE',
                    'reason': 'No key levels', 'symbol': symbol,
                }

            # ── STEP 2: Уровень в зоне ретеста ──
            retest_level        = None
            breakout_dir        = None
            proximity_threshold = atr_h1 * 0.7

            for lv in key_levels:
                if abs(current_price - lv['price']) > proximity_threshold:
                    continue
                bd = self.detect_level_breakout(df_h1, lv['price'])
                if bd:
                    retest_level = lv
                    breakout_dir = bd
                    logger.info(
                        f"[RETEST FOUND] ${lv['price']:.5f} | {bd} | "
                        f"{lv['strength']} ({lv['touches']} touches)"
                    )
                    break

            if not retest_level:
                return {
                    'score': 0, 'signal': 'NONE',
                    'reason': f"No retest near current price (checked {len(key_levels)} levels)",
                    'symbol': symbol, 'strategy': 'LEVEL_RETEST',
                }

            level_price = retest_level['price']

            # Базовый score за ретест
            base_score = 35 if retest_level['strength'] == 'STRONG' else 25
            score += base_score
            signals.append(
                f"✅ {retest_level['strength']} level retest @ {level_price:.5f} "
                f"({retest_level['touches']} touches)"
            )
            logger.info(f"[+{base_score}] Level retest confirmed")

            # ── STEP 3: Направление ──
            if breakout_dir == 'BROKE_ABOVE':
                trade_direction = 'LONG'
                candle_dir      = 'BULLISH'
                signals.append("📈 S/R Flip: resistance → support → BUY retest")
            else:
                trade_direction = 'SHORT'
                candle_dir      = 'BEARISH'
                signals.append("📉 S/R Flip: support → resistance → SELL retest")

            # ── STEP 4: Свеча отторжения на M15 ──
            has_rejection, rejection_msg = self.detect_rejection_candle(df_m15, candle_dir)
            if has_rejection:
                score += 25
                signals.append(rejection_msg)
                logger.info(f"[+25] {rejection_msg}")
            else:
                score += 5
                signals.append(f"⚠️ {rejection_msg} — consider waiting")
                logger.info(f"[+5] {rejection_msg}")

            # ── STEP 5: Volume (закрытая свеча!) ──
            last_vol = float(df_m15['tick_volume'].iloc[-2])        # последняя закрытая
            avg_vol  = float(df_m15['tick_volume'].iloc[-21:-2].mean())
            vol_ratio = last_vol / avg_vol if avg_vol > 0 else 1.0

            if vol_ratio >= 1.2:
                score += 15
                signals.append(f"✅ Volume {vol_ratio:.2f}x")
            else:
                signals.append(f"⚠️ Volume low {vol_ratio:.2f}x")
            logger.info(f"[VOL] {vol_ratio:.2f}x → score +{15 if vol_ratio >= 1.2 else 0}")

            # ── STEP 6: Session modifier ──
            score += session_info['score_modifier']
            if session_info['score_modifier'] > 0:
                signals.append(session_info['description'])

            # ── STEP 7: Proximity bonus ──
            dist_to_level = abs(current_price - level_price)
            if dist_to_level < atr_h1 * 0.3:
                score += 10
                signals.append(f"✅ Very close to level ({dist_to_level:.5f})")
                logger.info("[+10] Price very close to level")

            logger.info(f"\n[LEVEL RETEST SCORE] {score} / {Config.MIN_SCORE}")

            # ── STEP 8: SL / TP ──
            atr_buffer = atr_h1 * 0.5
            sl         = level_price + atr_buffer if trade_direction == 'SHORT' else level_price - atr_buffer
            tp_price   = self.find_next_target(key_levels, current_price, trade_direction)

            sl_dist  = abs(current_price - sl)
            tp_dist  = abs(current_price - tp_price) if tp_price else sl_dist * Config.MIN_RR_RATIO
            rr_ratio = tp_dist / sl_dist if sl_dist > 0 else 0

            if rr_ratio < Config.MIN_RR_RATIO:
                logger.warning(f"[LOW RR] {rr_ratio:.1f} < {Config.MIN_RR_RATIO} - skipping")
                return {
                    'score': score, 'signal': 'NONE',
                    'reason': f"RR too low: {rr_ratio:.1f}R (min {Config.MIN_RR_RATIO}R)",
                    'symbol': symbol, 'strategy': 'LEVEL_RETEST',
                }

            score += 10
            signals.append(f"✅ RR = {rr_ratio:.1f}R")

            # ── Финальный сигнал ──
            signal_type = trade_direction if score >= Config.MIN_SCORE else 'NONE'

            return {
                'score':          score,
                'signal':         signal_type,
                'entry_price':    current_price,
                'level_price':    level_price,
                'sl':             sl,
                'tp':             tp_price,
                'rr_ratio':       rr_ratio,
                'breakout_dir':   breakout_dir,
                'trade_direction': trade_direction,
                'volume_ratio':   vol_ratio,
                'reasons':        signals,
                'warnings':       [],
                'symbol':         symbol,
                'session_info':   session_info,
                'strategy':       'LEVEL_RETEST',
                'atr':            atr_h1,
            }

        except Exception as e:
            logger.error(f"LevelRetestAnalyzer.analyze error: {e}")
            import traceback; traceback.print_exc()
            return {
                'score': 0, 'signal': 'NONE',
                'reason': str(e), 'symbol': symbol,
                'strategy': 'LEVEL_RETEST',
            }


# ==================== POSITION TRACKER ====================
class PositionTracker:
    """Monitor positions and manage TP/SL progression with journal logging"""

    def __init__(self, mt5: MT5Connector, notifier: TelegramNotifier):
        self.mt5 = mt5
        self.notifier = notifier
        self.tracked_positions = {}
        self.trade_journal = None  # Linked by ForexTradingBot.__init__

    def track_position(self, ticket: int, signal: Dict):
        """Start tracking a new position"""
        self.tracked_positions[ticket] = {
            'symbol':        signal['symbol'],
            'direction':     signal['direction'],
            'entry':         signal['entry'],
            'tp1':           signal.get('tp1'),
            'tp2':           signal.get('tp2'),
            'tp3':           signal.get('tp3'),
            'tp4':           signal.get('tp4'),
            'tp_final':      signal.get('tp_final'),
            'sl':            signal.get('sl'),
            'source':        signal.get('source', 'AUTO'),
            'tp1_hit':       False,
            'tp2_hit':       False,
            'tp3_hit':       False,
            'tp4_hit':       False,
            'breakeven_set': False,
            'open_time':     datetime.utcnow(),
        }
        logger.info(
            f"[TRACK] Position #{ticket} | {signal['symbol']} {signal['direction']} | "
            f"TPs: {signal.get('tp1')}/{signal.get('tp2')}/{signal.get('tp3')}"
        )

    # ================================================================
    # MONITOR LOOP
    # ================================================================

    def monitor_positions(self):
        """Check all tracked positions for TP hits or unexpected closures"""
        try:
            open_positions = self.mt5.get_positions()
            open_tickets   = {p['ticket'] for p in open_positions}

            for ticket, data in list(self.tracked_positions.items()):

                # ── Position closed externally (SL hit or manual close) ──
                if ticket not in open_tickets:
                    self._handle_external_close(ticket, data)
                    continue

                pos           = next(p for p in open_positions if p['ticket'] == ticket)
                current_price = pos['current_price']
                direction     = data['direction']

                if direction == 'BUY':
                    if data['tp1'] and not data['tp1_hit'] and current_price >= data['tp1']:
                        self._handle_tp1_hit(ticket, data, pos)
                    if data['tp2'] and not data['tp2_hit'] and current_price >= data['tp2']:
                        self._handle_tp2_hit(ticket, data, pos)
                    if data['tp3'] and not data['tp3_hit'] and current_price >= data['tp3']:
                        self._handle_tp3_hit(ticket, data, pos)
                    if data['tp4'] and not data['tp4_hit'] and current_price >= data['tp4']:
                        self._handle_tp4_hit(ticket, data, pos)

                else:  # SELL
                    if data['tp1'] and not data['tp1_hit'] and current_price <= data['tp1']:
                        self._handle_tp1_hit(ticket, data, pos)
                    if data['tp2'] and not data['tp2_hit'] and current_price <= data['tp2']:
                        self._handle_tp2_hit(ticket, data, pos)
                    if data['tp3'] and not data['tp3_hit'] and current_price <= data['tp3']:
                        self._handle_tp3_hit(ticket, data, pos)
                    if data['tp4'] and not data['tp4_hit'] and current_price <= data['tp4']:
                        self._handle_tp4_hit(ticket, data, pos)

        except Exception as e:
            logger.error(f"Monitor positions error: {e}")

    # ================================================================
    # TP HANDLERS
    # ================================================================

    def _handle_tp1_hit(self, ticket: int, data: Dict, pos: Dict):
        """TP1 hit → Move SL to breakeven"""
        try:
            logger.info(f"[TP1 HIT] #{ticket} {data['symbol']}")
            entry = data['entry']

            if Config.BREAKEVEN_AFTER_TP1:
                self.mt5.modify_sl_tp(ticket, new_sl=entry, new_tp=pos['tp'])
                data['breakeven_set'] = True

            data['tp1_hit'] = True

            # Check if TP1 is the last TP → log as closed
            has_more_tps = any(data.get(f'tp{i}') for i in range(2, 5))
            if not has_more_tps:
                self._log_close_to_journal(ticket, data, pos, "TP1")
                del self.tracked_positions[ticket]

            self.notifier.send(
                f"✅ TP1 REACHED\n\n"
                f"Symbol: {data['symbol']}\n"
                f"Position: #{ticket}\n"
                f"SL → Breakeven: {entry:.5f}\n"
                f"Profit: ${pos['profit']:.2f}",
                urgent=False
            )

        except Exception as e:
            logger.error(f"TP1 handler error: {e}")

    def _handle_tp2_hit(self, ticket: int, data: Dict, pos: Dict):
        """TP2 hit → Move SL to TP1"""
        try:
            logger.info(f"[TP2 HIT] #{ticket} {data['symbol']}")

            if Config.MOVE_SL_TO_TP1_AFTER_TP2 and data.get('tp1'):
                self.mt5.modify_sl_tp(ticket, new_sl=data['tp1'], new_tp=pos['tp'])

            data['tp2_hit'] = True

            # Check if TP2 is the last TP
            has_more_tps = any(data.get(f'tp{i}') for i in range(3, 5))
            if not has_more_tps:
                self._log_close_to_journal(ticket, data, pos, "TP2")
                del self.tracked_positions[ticket]

            self.notifier.send(
                f"🎯 TP2 REACHED\n\n"
                f"Symbol: {data['symbol']}\n"
                f"Position: #{ticket}\n"
                f"SL → TP1: {data.get('tp1', 'N/A')}\n"
                f"Profit: ${pos['profit']:.2f}",
                urgent=False
            )

        except Exception as e:
            logger.error(f"TP2 handler error: {e}")

    def _handle_tp3_hit(self, ticket: int, data: Dict, pos: Dict):
        """TP3 hit → Close or move SL to TP2"""
        try:
            logger.info(f"[TP3 HIT] #{ticket} {data['symbol']}")
            data['tp3_hit'] = True

            if data.get('tp4'):
                # TP4 exists → just move SL to TP2
                if data.get('tp2'):
                    self.mt5.modify_sl_tp(ticket, new_sl=data['tp2'], new_tp=pos['tp'])
                self.notifier.send(
                    f"🎯 TP3 REACHED\n\n"
                    f"Symbol: {data['symbol']}\n"
                    f"Position: #{ticket}\n"
                    f"SL → TP2: {data.get('tp2', 'N/A')}\n"
                    f"Waiting for TP4...\n"
                    f"Profit: ${pos['profit']:.2f}",
                    urgent=False
                )
            else:
                # No TP4 → close position
                if Config.CLOSE_ALL_AT_TP3:
                    profit_usd = pos['profit']
                    self.mt5.close_trade(ticket)
                    self._log_close_to_journal(ticket, data, pos, "TP3")
                    del self.tracked_positions[ticket]

                    self.notifier.send(
                        f"🎉 TP3 REACHED — CLOSED\n\n"
                        f"Symbol: {data['symbol']}\n"
                        f"Position: #{ticket}\n"
                        f"Final Profit: ${profit_usd:.2f}",
                        urgent=True
                    )

        except Exception as e:
            logger.error(f"TP3 handler error: {e}")

    def _handle_tp4_hit(self, ticket: int, data: Dict, pos: Dict):
        """TP4 hit → Close position (final target)"""
        try:
            logger.info(f"[TP4 HIT] #{ticket} {data['symbol']}")
            data['tp4_hit'] = True

            profit_usd = pos['profit']
            self.mt5.close_trade(ticket)
            self._log_close_to_journal(ticket, data, pos, "TP4")

            if ticket in self.tracked_positions:
                del self.tracked_positions[ticket]

            self.notifier.send(
                f"🏆 TP4 REACHED — CLOSED\n\n"
                f"Symbol: {data['symbol']}\n"
                f"Position: #{ticket}\n"
                f"Final Profit: ${profit_usd:.2f}",
                urgent=True
            )

        except Exception as e:
            logger.error(f"TP4 handler error: {e}")

    # ================================================================
    # EXTERNAL CLOSE HANDLER (SL hit / manual close)
    # ================================================================

    def _handle_external_close(self, ticket: int, data: Dict):
        """
        Position closed outside our bot (SL triggered, manual close).
        Determines outcome: SL or B/E based on entry vs close.
        """
        try:
            logger.info(f"[EXTERNAL CLOSE] #{ticket} {data['symbol']} — detecting outcome...")

            # Try to get last deal from history
            from_time = data.get('open_time', datetime.utcnow() - timedelta(hours=48))

            deals = mt5.history_deals_get(from_time, datetime.utcnow())
            close_deal = None

            if deals:
                for deal in reversed(deals):
                    if deal.position_id == ticket and deal.entry == mt5.DEAL_ENTRY_OUT:
                        close_deal = deal
                        break

            entry_price = data['entry']

            if close_deal:
                close_price = close_deal.price
                profit_usd  = close_deal.profit
            else:
                # Fallback: use entry, assume SL
                close_price = data.get('sl', entry_price)
                profit_usd  = 0.0

            # Calculate result %
            price_diff = close_price - entry_price
            if data['direction'] == 'SELL':
                price_diff = -price_diff

            result_pct = (price_diff / entry_price) * 100

            # Determine outcome
            if abs(result_pct) < 0.05 or data.get('breakeven_set'):
                outcome = "B/E"
                result_pct = 0.0
            elif result_pct < 0:
                outcome = "SL"
            else:
                # Closed profitably but not by our TP handlers (edge case)
                if data.get('tp2_hit'):
                    outcome = "TP3"
                elif data.get('tp1_hit'):
                    outcome = "TP2"
                else:
                    outcome = "TP1"

            logger.info(
                f"[EXTERNAL CLOSE] #{ticket} {data['symbol']} → {outcome} "
                f"({result_pct:+.2f}%) | P/L: ${profit_usd:.2f}"
            )

            # Log to journal
            if self.trade_journal:
                self.trade_journal.log_trade_close(
                    ticket=ticket,
                    symbol=data['symbol'],
                    direction=data['direction'],
                    outcome=outcome,
                    result_pct=result_pct,
                    entry=entry_price,
                    close_price=close_price,
                    profit_usd=profit_usd
                )

            # Notify
            emoji = "❌" if outcome == "SL" else ("➖" if outcome == "B/E" else "✅")
            self.notifier.send(
                f"{emoji} POSITION CLOSED\n\n"
                f"Symbol: {data['symbol']}\n"
                f"Direction: {data['direction']}\n"
                f"Outcome: {outcome}\n"
                f"Result: {result_pct:+.2f}%\n"
                f"P/L: ${profit_usd:.2f}\n"
                f"Ticket: #{ticket}",
                urgent=(outcome == "SL")
            )

            del self.tracked_positions[ticket]

        except Exception as e:
            logger.error(f"External close handler error: {e}")
            if ticket in self.tracked_positions:
                del self.tracked_positions[ticket]

    # ================================================================
    # JOURNAL HELPER
    # ================================================================

    def _log_close_to_journal(self, ticket: int, data: Dict, pos: Dict, outcome: str):
        """Calculate result % and write to journal"""
        try:
            if not self.trade_journal:
                return

            entry_price   = data['entry']
            close_price   = pos['current_price']
            profit_usd    = pos['profit']

            price_diff = close_price - entry_price
            if data['direction'] == 'SELL':
                price_diff = -price_diff

            result_pct = (price_diff / entry_price) * 100

            self.trade_journal.log_trade_close(
                ticket=ticket,
                symbol=data['symbol'],
                direction=data['direction'],
                outcome=outcome,
                result_pct=result_pct,
                entry=entry_price,
                close_price=close_price,
                profit_usd=profit_usd
            )

        except Exception as e:
            logger.error(f"Journal log close error: {e}")

    # ================================================================
    # CLOSE ALL
    # ================================================================

    def close_all_positions(self, reason: str = "Manual close"):
        """Force-close all open positions"""
        try:
            positions = self.mt5.get_positions()

            if not positions:
                logger.info("[CLOSE ALL] No open positions")
                return

            closed_count = 0

            for pos in positions:
                ticket    = pos['ticket']
                symbol    = pos['symbol']
                profit    = pos['profit']
                entry     = pos['open_price']
                direction = pos['type']

                success = self.mt5.close_trade(ticket)

                if success:
                    closed_count += 1
                    logger.info(f"[FORCE CLOSE] #{ticket} {symbol} — {reason} | P/L: ${profit:.2f}")

                    # Determine journal outcome
                    data = self.tracked_positions.get(ticket, {
                        'symbol': symbol, 'direction': direction,
                        'entry': entry, 'breakeven_set': False
                    })

                    price_diff = pos['current_price'] - entry
                    if direction == 'SELL':
                        price_diff = -price_diff
                    result_pct = (price_diff / entry) * 100

                    if abs(result_pct) < 0.05:
                        outcome = "B/E"
                        result_pct = 0.0
                    elif result_pct < 0:
                        outcome = "SL"
                    else:
                        outcome = "Manual"

                    if self.trade_journal:
                        self.trade_journal.log_trade_close(
                            ticket=ticket,
                            symbol=symbol,
                            direction=direction,
                            outcome=outcome,
                            result_pct=result_pct,
                            entry=entry,
                            close_price=pos['current_price'],
                            profit_usd=profit
                        )

                    if ticket in self.tracked_positions:
                        del self.tracked_positions[ticket]

            self.notifier.send(
                f"⚠️ ALL POSITIONS CLOSED\n\n"
                f"Reason: {reason}\n"
                f"Closed: {closed_count}/{len(positions)} positions",
                urgent=True
            )

        except Exception as e:
            logger.error(f"Close all positions error: {e}")

# ==================== TRADING SCHEDULE MANAGER ====================
class ScheduleManager:
    """Manage trading hours and news avoidance"""

    @staticmethod
    def can_trade_now() -> Tuple[bool, str]:
        """Check if trading is allowed"""
        try:
            now = datetime.utcnow()
            weekday = now.weekday()
            hour = now.hour

            # Saturday: closed
            if weekday == 5:
                return False, "Saturday - Forex market closed"

            # Sunday: opens at 22:00 GMT
            if weekday == 6:
                if hour < 22:
                    return False, f"Sunday before 22:00 GMT - Market opens at 22:00 (now: {hour:02d}:{now.minute:02d} GMT)"
                else:
                    return True, "Trading allowed (Sunday 22:00+ GMT)"

            # Friday: closes at 22:00 GMT
            if weekday == 4:
                if hour >= Config.FRIDAY_CLOSE_HOUR_GMT:
                    return False, f"Friday after {Config.FRIDAY_CLOSE_HOUR_GMT:02d}:00 GMT - No new trades"

            # Check high-impact news
            for day, news_hour, minute in Config.HIGH_IMPACT_NEWS_HOURS:
                if weekday == day and hour == news_hour and abs(now.minute - minute) <= 30:
                    return False, f"High-impact news at {news_hour}:{minute:02d} GMT"

            return True, "Trading allowed"

        except Exception as e:
            logger.error(f"Schedule check error: {e}")
            return True, "Schedule check failed - trading allowed"

    @staticmethod
    def should_close_positions_for_weekend() -> bool:
        """Check if it's time to close positions before weekend"""
        try:
            now = datetime.utcnow()
            if now.weekday() == 4 and now.hour >= Config.FRIDAY_CLOSE_HOUR_GMT:
                return True
            return False
        except Exception as e:
            logger.error(f"Weekend check error: {e}")
            return False

