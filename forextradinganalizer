# ==================== MT5 CONNECTION ====================
class MT5Connector:
    """MetaTrader 5 API wrapper"""

    def __init__(self):
        self.connected = False
        self.initialize()

    def initialize(self) -> bool:
        """Initialize MT5 connection"""
        try:
            if not mt5.initialize():
                logger.error(f"MT5 initialize failed: {mt5.last_error()}")
                return False

            if not mt5.login(Config.MT5_LOGIN, Config.MT5_PASSWORD, Config.MT5_SERVER):
                logger.error(f"MT5 login failed: {mt5.last_error()}")
                return False

            account_info = mt5.account_info()
            if account_info is None:
                logger.error("Failed to get account info")
                return False

            logger.info(f"[OK] MT5 Connected")
            logger.info(f"  Account: {account_info.login}")
            logger.info(f"  Server: {account_info.server}")
            logger.info(f"  Balance: ${account_info.balance:.2f}")
            logger.info(f"  Equity: ${account_info.equity:.2f}")

            self.connected = True
            return True

        except Exception as e:
            logger.error(f"MT5 initialization error: {e}")
            return False

    def get_balance(self) -> float:
        """Get account equity"""
        try:
            account_info = mt5.account_info()
            if account_info is None:
                return 0.0
            return float(account_info.equity)
        except Exception as e:
            logger.error(f"Get balance error: {e}")
            return 0.0

    def get_symbol_info(self, symbol: str) -> Optional[Dict]:
        """Get symbol specifications"""
        try:
            info = mt5.symbol_info(symbol)
            if info is None:
                logger.error(f"Symbol {symbol} not found")
                return None

            return {
                'symbol': symbol,
                'digits': info.digits,
                'point': info.point,
                'min_lot': info.volume_min,
                'max_lot': info.volume_max,
                'lot_step': info.volume_step,
                'contract_size': info.trade_contract_size,
                'tick_value': info.trade_tick_value,
                'tick_size': info.trade_tick_size,
            }
        except Exception as e:
            logger.error(f"Get symbol info error: {e}")
            return None

    def get_tick(self, symbol: str) -> Optional[Dict]:
        """Get current price tick"""
        try:
            tick = mt5.symbol_info_tick(symbol)
            if tick is None:
                return None

            return {
                'symbol': symbol,
                'bid': float(tick.bid),
                'ask': float(tick.ask),
                'last': float(tick.last),
                'time': tick.time
            }
        except Exception as e:
            logger.error(f"Get tick error: {e}")
            return None

    def open_trade(self, symbol: str, direction: str, lot: float,
                   sl: float, tp: float, comment: str = "") -> Optional[int]:
        """Open trade with SL/TP"""
        try:
            tick = self.get_tick(symbol)
            if not tick:
                logger.error(f"Cannot get price for {symbol}")
                return None

            if direction == "BUY":
                order_type = mt5.ORDER_TYPE_BUY
                price = tick['ask']
            else:
                order_type = mt5.ORDER_TYPE_SELL
                price = tick['bid']

            request = {
                "action": mt5.TRADE_ACTION_DEAL,
                "symbol": symbol,
                "volume": lot,
                "type": order_type,
                "price": price,
                "sl": sl,
                "tp": tp if tp else 0.0,
                "deviation": 20,
                "magic": 234000,
                "comment": comment,
                "type_time": mt5.ORDER_TIME_GTC,
                "type_filling": mt5.ORDER_FILLING_IOC,
            }

            logger.info(f"[OPEN TRADE] {symbol} {direction}")
            logger.info(f"  Lot: {lot}")
            logger.info(f"  Price: {price:.5f}")
            logger.info(f"  SL: {sl:.5f}")
            logger.info(f"  TP: {tp:.5f}" if tp else "  TP: Manual")

            result = mt5.order_send(request)

            if result is None:
                logger.error(f"order_send failed: {mt5.last_error()}")
                return None

            if result.retcode != mt5.TRADE_RETCODE_DONE:
                logger.error(f"Order failed: {result.retcode} - {result.comment}")
                return None

            logger.info(f"[OK] Trade opened: Ticket #{result.order}")
            return result.order

        except Exception as e:
            logger.error(f"Open trade error: {e}")
            return None

    def close_trade(self, ticket: int) -> bool:
        """Close position by ticket"""
        try:
            position = mt5.positions_get(ticket=ticket)
            if not position or len(position) == 0:
                logger.warning(f"Position {ticket} not found")
                return False

            pos = position[0]
            symbol = pos.symbol
            lot = pos.volume

            if pos.type == mt5.ORDER_TYPE_BUY:
                order_type = mt5.ORDER_TYPE_SELL
                price = mt5.symbol_info_tick(symbol).bid
            else:
                order_type = mt5.ORDER_TYPE_BUY
                price = mt5.symbol_info_tick(symbol).ask

            request = {
                "action": mt5.TRADE_ACTION_DEAL,
                "symbol": symbol,
                "volume": lot,
                "type": order_type,
                "position": ticket,
                "price": price,
                "deviation": 20,
                "magic": 234000,
                "comment": "close",
                "type_time": mt5.ORDER_TIME_GTC,
                "type_filling": mt5.ORDER_FILLING_IOC,
            }

            result = mt5.order_send(request)
            if result.retcode != mt5.TRADE_RETCODE_DONE:
                logger.error(f"Close failed: {result.retcode}")
                return False

            logger.info(f"[OK] Position closed: #{ticket}")
            return True

        except Exception as e:
            logger.error(f"Close trade error: {e}")
            return False

    def modify_sl_tp(self, ticket: int, new_sl: float, new_tp: float = None) -> bool:
        """Modify SL/TP of existing position"""
        try:
            position = mt5.positions_get(ticket=ticket)
            if not position or len(position) == 0:
                logger.warning(f"Position {ticket} not found")
                return False

            pos = position[0]

            if new_tp is None:
                new_tp = pos.tp

            request = {
                "action": mt5.TRADE_ACTION_SLTP,
                "position": ticket,
                "sl": new_sl,
                "tp": new_tp,
            }

            result = mt5.order_send(request)
            if result.retcode != mt5.TRADE_RETCODE_DONE:
                logger.error(f"Modify SL/TP failed: {result.retcode}")
                return False

            logger.info(f"[OK] SL/TP modified: #{ticket} → SL={new_sl:.5f}, TP={new_tp:.5f}")
            return True

        except Exception as e:
            logger.error(f"Modify SL/TP error: {e}")
            return False

    def get_positions(self) -> List[Dict]:
        """Get all open positions"""
        try:
            positions = mt5.positions_get()
            if positions is None:
                return []

            result = []
            for pos in positions:
                result.append({
                    'ticket': pos.ticket,
                    'symbol': pos.symbol,
                    'type': 'BUY' if pos.type == mt5.ORDER_TYPE_BUY else 'SELL',
                    'volume': pos.volume,
                    'open_price': pos.price_open,
                    'current_price': pos.price_current,
                    'sl': pos.sl,
                    'tp': pos.tp,
                    'profit': pos.profit,
                    'swap': pos.swap,
                    'comment': pos.comment,
                    'time': pos.time,
                })
            return result

        except Exception as e:
            logger.error(f"Get positions error: {e}")
            return []

    def get_ohlcv(self, symbol: str, timeframe: str, bars: int = 500) -> pd.DataFrame:
        """Get OHLCV data"""
        try:
            tf_map = {
                "M1": mt5.TIMEFRAME_M1,
                "M5": mt5.TIMEFRAME_M5,
                "M15": mt5.TIMEFRAME_M15,
                "M30": mt5.TIMEFRAME_M30,
                "H1": mt5.TIMEFRAME_H1,
                "H4": mt5.TIMEFRAME_H4,
                "D1": mt5.TIMEFRAME_D1,
            }

            if timeframe not in tf_map:
                logger.error(f"Unknown timeframe: {timeframe}")
                return pd.DataFrame()

            rates = mt5.copy_rates_from_pos(symbol, tf_map[timeframe], 0, bars)
            if rates is None or len(rates) == 0:
                logger.error(f"No data for {symbol} {timeframe}")
                return pd.DataFrame()

            df = pd.DataFrame(rates)
            df['time'] = pd.to_datetime(df['time'], unit='s')
            return df[['time', 'open', 'high', 'low', 'close', 'tick_volume']]

        except Exception as e:
            logger.error(f"Get OHLCV error: {e}")
            return pd.DataFrame()

def open_limit_order(self, symbol: str, direction: str, lot: float,
                     price: float, sl: float, tp: float,
                     comment: str = "", expiry_hours: int = 48) -> Optional[int]:
    """Place pending LIMIT order at exact price"""
    try:
        if direction == "BUY":
            order_type = mt5.ORDER_TYPE_BUY_LIMIT
        else:
            order_type = mt5.ORDER_TYPE_SELL_LIMIT

        expiration = datetime.utcnow() + timedelta(hours=expiry_hours)

        request = {
            "action":      mt5.TRADE_ACTION_PENDING,
            "symbol":      symbol,
            "volume":      lot,
            "type":        order_type,
            "price":       price,
            "sl":          sl,
            "tp":          tp if tp else 0.0,
            "deviation":   20,
            "magic":       234000,
            "comment":     comment,
            "type_time":   mt5.ORDER_TIME_SPECIFIED,
            "expiration":  int(expiration.timestamp()),
            "type_filling": mt5.ORDER_FILLING_RETURN,
        }

        logger.info(f"[LIMIT ORDER] {symbol} {direction}")
        logger.info(f"  Price: {price:.5f} | SL: {sl:.5f} | TP: {tp:.5f}")
        logger.info(f"  Lot: {lot} | Expires in {expiry_hours}h")

        result = mt5.order_send(request)

        if result is None:
            logger.error(f"order_send failed: {mt5.last_error()}")
            return None

        if result.retcode != mt5.TRADE_RETCODE_DONE:
            logger.error(f"Limit order failed: {result.retcode} - {result.comment}")
            return None

        logger.info(f"[OK] Limit order placed: Ticket #{result.order}")
        return result.order

    except Exception as e:
        logger.error(f"Open limit order error: {e}")
        return None


# ==================== TELEGRAM NOTIFIER ====================
class TelegramNotifier:
    """Telegram notifications + manual signal parsing"""

    def __init__(self, token: str, chat_id: str):
        self.token = token
        self.chat_id = chat_id
        self.base_url = f"https://api.telegram.org/bot{token}/sendMessage"
        self.pending_signals = {}

    def send(self, message: str, urgent: bool = False):
        """Send notification"""
        try:
            emoji = "🚨" if urgent else "ℹ️"
            full_message = f"{emoji} {message}"

            payload = {
                'chat_id': self.chat_id,
                'text': full_message,
                'parse_mode': 'HTML'
            }

            response = requests.post(self.base_url, data=payload, timeout=10)
            if response.status_code != 200:
                logger.error(f"Telegram send failed: {response.text}")
        except Exception as e:
            logger.error(f"Telegram error: {e}")

    def send_with_buttons(self, message: str, buttons: List[Tuple[str, str]]):
        """Send message with inline buttons"""
        try:
            keyboard = [[InlineKeyboardButton(text, callback_data=data)] for text, data in buttons]
            reply_markup = InlineKeyboardMarkup(keyboard)

            url = f"https://api.telegram.org/bot{self.token}/sendMessage"
            payload = {
                'chat_id': self.chat_id,
                'text': message,
                'reply_markup': json.dumps(reply_markup.to_dict()),
                'parse_mode': 'HTML'
            }

            requests.post(url, data=payload, timeout=10)
        except Exception as e:
            logger.error(f"Send buttons error: {e}")

    def parse_arut_signal(self, text: str) -> Optional[Dict]:
        """Parse Arut signal format"""
        try:
            lines = [line.strip() for line in text.split('\n') if line.strip()]
            if len(lines) < 4:
                return None

            first_line = lines[0].upper()
            if 'BUY' in first_line:
                direction = 'BUY'
            elif 'SELL' in first_line:
                direction = 'SELL'
            else:
                return None

            symbol = None
            for pair in Config.TRADING_PAIRS:
                if pair in first_line:
                    symbol = pair
                    break

            if not symbol:
                return None

            entry_line = lines[1]
            entry_match = re.findall(r'\d+\.\d+', entry_line)
            if len(entry_match) >= 1:
                entry_price = float(entry_match[0])
            else:
                return None

            tp1 = tp2 = tp3 = None
            sl = None

            for line in lines[2:]:
                line_upper = line.upper()
                prices = re.findall(r'\d+\.\d+', line)
                if not prices:
                    continue

                price = float(prices[0])

                if 'TAKE PROFIT 1' in line_upper or 'TP1' in line_upper or 'TP 1' in line_upper:
                    tp1 = price
                elif 'TAKE PROFIT 2' in line_upper or 'TP2' in line_upper or 'TP 2' in line_upper:
                    tp2 = price
                elif 'TAKE PROFIT 3' in line_upper or 'TP3' in line_upper or 'TP 3' in line_upper:
                    tp3 = price
                elif 'STOP LOSS' in line_upper or 'SL' in line_upper:
                    sl = price

            if not sl:
                return None

            return {
                'symbol': symbol,
                'direction': direction,
                'entry': entry_price,
                'tp1': tp1,
                'tp2': tp2,
                'tp3': tp3,
                'sl': sl,
                'source': 'ARUT'
            }

        except Exception as e:
            logger.error(f"Parse signal error: {e}")
            return None

# ==================== 🆕 SESSION FILTER ====================
class SessionFilter:
    """Фильтр активных торговых сессий"""
    
    @staticmethod
    def get_current_session() -> Dict:
        """Определить текущую сессию (GMT)"""
        try:
            now = datetime.utcnow()
            hour = now.hour
            weekday = now.weekday()
            
            # Выходные
            if weekday == 5 or (weekday == 6 and hour < 22):
                return {
                    'session': 'WEEKEND_CLOSED',
                    'active': False,
                    'score_modifier': -50,
                    'description': '⛔ Weekend - Market closed'
                }
            
            # Пятница после 21:00 GMT
            if weekday == 4 and hour >= 21:
                return {
                    'session': 'FRIDAY_CLOSE',
                    'active': False,
                    'score_modifier': -30,
                    'description': '⚠️ Friday close - Low liquidity'
                }
            
            # Overlap Лондон + Нью-Йорк (ЛУЧШЕЕ ВРЕМЯ!)
            if 13 <= hour < 17:  # 13:00-17:00 GMT
                return {
                    'session': 'LONDON_NY_OVERLAP',
                    'active': True,
                    'score_modifier': 20,
                    'description': '🔥 London-NY Overlap - BEST TIME'
                }
            
            # Лондонская сессия (8:00-17:00 GMT)
            if 8 <= hour < 17:
                return {
                    'session': 'LONDON',
                    'active': True,
                    'score_modifier': 10,
                    'description': '✅ London Session - High liquidity'
                }
            
            # Нью-Йорк (13:00-22:00 GMT)
            if 13 <= hour < 22:
                return {
                    'session': 'NEW_YORK',
                    'active': True,
                    'score_modifier': 10,
                    'description': '✅ New York Session - Active'
                }
            
            # Азиатская сессия / мертвые часы
            return {
                'session': 'ASIAN_OR_QUIET',
                'active': False,
                'score_modifier': -30,
                'description': '⚠️ Asian/Quiet hours - Low volume'
            }
            
        except Exception as e:
            logger.error(f"Session filter error: {e}")
            return {
                'session': 'UNKNOWN',
                'active': True,
                'score_modifier': 0,
                'description': 'Unknown session'
            }
    
    @staticmethod
    def can_trade_now() -> Tuple[bool, str]:
        """Можно ли торговать сейчас"""
        session_info = SessionFilter.get_current_session()
        return session_info['active'], session_info.get('description', 'N/A')
    
    @staticmethod
    def check_volume_confirmation(df: pd.DataFrame, min_ratio: float = 1.2) -> Tuple[bool, float]:
        """Проверка объема для подтверждения сигнала"""
        try:
            if len(df) < 20:
                return False, 0.0
            
            current_volume = df['tick_volume'].iloc[-1]
            avg_volume = df['tick_volume'].iloc[-20:-1].mean()
            
            if avg_volume == 0:
                return False, 0.0
            
            volume_ratio = current_volume / avg_volume
            
            if volume_ratio >= min_ratio:
                return True, volume_ratio
            
            return False, volume_ratio
            
        except Exception as e:
            logger.error(f"Volume check error: {e}")
            return False, 0.0


# ==================== RISK MANAGER ====================
class RiskManager:
    """Calculate position size, SL/TP levels with FREE MARGIN check"""

    def __init__(self, mt5: MT5Connector):
        self.mt5 = mt5

    # ──────────────────────────────────────────────────
    # MARGIN HELPERS
    # ──────────────────────────────────────────────────

    def get_free_margin(self) -> float:
        """Получить СВОБОДНУЮ маржу (не баланс!)"""
        try:
            account_info = mt5.account_info()
            if account_info is None:
                logger.error("Cannot get account info")
                return 0.0

            free_margin  = float(account_info.margin_free)
            equity       = float(account_info.equity)
            margin_level = float(account_info.margin_level) if account_info.margin_level else 0

            logger.info(f"[MARGIN INFO]")
            logger.info(f"  Equity: ${equity:.2f}")
            logger.info(f"  Free Margin: ${free_margin:.2f}")
            logger.info(f"  Margin Level: {margin_level:.1f}%")

            return free_margin

        except Exception as e:
            logger.error(f"Get free margin error: {e}")
            return 0.0

    def can_open_position(self, required_margin: float) -> Tuple[bool, str]:
        """Проверка доступности маржи ПЕРЕД открытием"""
        try:
            free_margin      = self.get_free_margin()
            max_usage        = Config.MAX_MARGIN_USAGE           # e.g. 0.70
            available_margin = free_margin * max_usage

            if required_margin > available_margin:
                return False, f"Not enough margin: ${required_margin:.2f} > ${available_margin:.2f}"

            if required_margin > free_margin * 0.90:
                return True, f"⚠️ High margin usage: {(required_margin / free_margin) * 100:.1f}%"

            return True, "OK"

        except Exception as e:
            logger.error(f"Margin check error: {e}")
            return False, str(e)

    # ──────────────────────────────────────────────────
    # LOT CALCULATION
    # ──────────────────────────────────────────────────

    def calculate_lot_size(
        self, symbol: str, entry: float, sl: float,
        balance: float, risk_pct: float = 0.01
    ) -> float:
        """Calculate lot size based on risk with FREE MARGIN validation"""
        try:
            logger.info(f"[LOT CALCULATION] {symbol}")

            account_info = mt5.account_info()
            if account_info:
                equity = float(account_info.equity)
                logger.info(f"  Equity: ${equity:.2f}")
            else:
                equity = balance
                logger.info(f"  Balance: ${balance:.2f}")

            risk_amount = equity * risk_pct
            logger.info(f"  Risk: {risk_pct * 100:.1f}% = ${risk_amount:.2f}")
            logger.info(f"  Entry: {entry:.5f}, SL: {sl:.5f}")

            symbol_info = mt5.symbol_info(symbol)
            if not symbol_info:
                logger.error(f"Symbol {symbol} not found")
                return 0.0

            sl_distance   = abs(entry - sl)
            tick_size     = symbol_info.trade_tick_size
            tick_value    = symbol_info.trade_tick_value
            contract_size = symbol_info.trade_contract_size
            min_lot       = symbol_info.volume_min
            max_lot       = symbol_info.volume_max
            lot_step      = symbol_info.volume_step

            logger.info(f"  Distance: {sl_distance:.5f}")
            logger.info(f"  Tick size: {tick_size}, Tick value: ${tick_value:.2f}")
            logger.info(f"  Contract size: {contract_size}")

            ticks        = sl_distance / tick_size
            money_per_lot = ticks * tick_value

            if money_per_lot == 0:
                logger.error("Money per lot = 0")
                return 0.0

            raw_lot = risk_amount / money_per_lot
            logger.info(f"  Ticks: {ticks:.0f}, Money per lot: ${money_per_lot:.2f}")
            logger.info(f"  Raw lot: {raw_lot:.4f}")

            lot = round(raw_lot / lot_step) * lot_step
            lot = max(min_lot, min(lot, max_lot))

            # ── Проверка маржи ──
            order_type = mt5.ORDER_TYPE_SELL if sl > entry else mt5.ORDER_TYPE_BUY
            margin     = mt5.order_calc_margin(order_type, symbol, lot, entry)

            if margin is None:
                logger.warning(f"  Cannot calculate margin, using lot {lot:.2f}")
            else:
                logger.info(f"  Required margin: ${margin:.2f}")

                can_open, reason = self.can_open_position(margin)

                if not can_open:
                    logger.error(f"  [BLOCKED] {reason}")

                    free_margin = self.get_free_margin()
                    if free_margin > 0 and margin > 0:
                        reduced_lot = (free_margin * Config.MAX_MARGIN_USAGE) / (margin / lot)
                        reduced_lot = max(min_lot, round(reduced_lot / lot_step) * lot_step)

                        if reduced_lot >= min_lot:
                            logger.info(f"  [REDUCED] Lot from {lot:.2f} to {reduced_lot:.2f}")
                            lot = reduced_lot
                        else:
                            logger.error("  [REJECTED] Cannot reduce lot enough")
                            return 0.0
                    else:
                        return 0.0
                else:
                    if "⚠️" in reason:
                        logger.warning(f"  {reason}")

            logger.info(f"  [FINAL] Lot: {lot:.2f}")
            return lot

        except Exception as e:
            logger.error(f"Calculate lot error: {e}")
            return 0.0

    # ──────────────────────────────────────────────────
    # SL VALIDATION
    # ──────────────────────────────────────────────────

    def validate_sl_distance(self, entry: float, sl: float, symbol: str = None) -> bool:
        """Check if SL distance is valid"""
        try:
            distance_pct = abs(entry - sl) / entry

            if symbol and symbol in ['GOLD', 'XAUUSD', 'XAGUSD']:
                min_sl     = 0.001
                max_sl     = 0.015
                asset_name = "GOLD"
            else:
                min_sl     = Config.MIN_SL_DISTANCE_PCT
                max_sl     = Config.MAX_SL_DISTANCE_PCT
                asset_name = "Forex"

            tolerance = 0.98    # 2% tolerance

            if distance_pct < min_sl * tolerance:
                logger.warning(
                    f"SL too close: {distance_pct * 100:.2f}% < {min_sl * 100:.2f}% ({asset_name} limit)"
                )
                return False

            if distance_pct > max_sl * 1.02:
                logger.warning(
                    f"SL too far: {distance_pct * 100:.2f}% > {max_sl * 100:.2f}% ({asset_name} limit)"
                )
                return False

            logger.info(f"  [SL OK] {distance_pct * 100:.2f}% (within {asset_name} range)")
            return True

        except Exception as e:
            logger.error(f"Validate SL error: {e}")
            return False

    # ──────────────────────────────────────────────────
    # DYNAMIC SL
    # ──────────────────────────────────────────────────

    def calculate_dynamic_sl(self, df: pd.DataFrame, direction: str, entry: float) -> float:
        """Calculate SL based on ATR"""
        try:
            if len(df) < 20:
                return entry * 0.992 if direction == 'BUY' else entry * 1.008

            high  = df['high']
            low   = df['low']
            close = df['close']

            tr1 = high - low
            tr2 = abs(high - close.shift())
            tr3 = abs(low - close.shift())
            tr  = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
            atr = tr.rolling(window=14).mean().iloc[-1]

            sl_distance = atr * 4.0
            min_distance = entry * Config.MIN_SL_DISTANCE_PCT
            max_distance = entry * Config.MAX_SL_DISTANCE_PCT
            sl_distance  = max(min_distance, min(sl_distance, max_distance))

            sl = entry - sl_distance if direction == 'BUY' else entry + sl_distance

            logger.info(f"[DYNAMIC SL] ATR={atr:.5f}, Distance={sl_distance:.5f}, SL={sl:.5f}")
            return sl

        except Exception as e:
            logger.error(f"Dynamic SL error: {e}")
            return entry * 0.992 if direction == 'BUY' else entry * 1.008

