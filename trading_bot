            return path
        except Exception as e:
            self.logger.warning(f"Chart render failed for {symbol}: {e}")
            return None

    # ---------- Market data ----------
    def _fetch_klines(self, symbol: str, tf: str, limit: int = 220):
        # Try Binance Futures first, then Spot
        symbol = self._normalize_symbol(symbol)
        tf = self._normalize_tf(tf)

        endpoints = [
            ("https://fapi.binance.com/fapi/v1/klines", {"symbol": symbol, "interval": tf, "limit": limit}),
            ("https://api.binance.com/api/v3/klines", {"symbol": symbol, "interval": tf, "limit": limit}),
        ]

        for url, params in endpoints:
            try:
                r = self.session.get(url, params=params, timeout=15)
                if r.status_code == 200:
                    data = r.json()
                    if isinstance(data, list) and data:
                        out = []
                        for row in data:
                            out.append([
                                row[0], row[1], row[2], row[3], row[4], row[5], row[6]
                            ])
                        return out
            except Exception:
                continue

        return None

    # ---------- Parsing ----------
    def _normalize_tf(self, tf: str):
        tf = (tf or self.default_tf).strip().lower()
        allowed = {"5m", "15m", "1h", "4h", "1d"}
        return tf if tf in allowed else self.default_tf

    def _normalize_symbol(self, raw: str):
        s = (raw or "").upper().strip()

        # BTC/USDT:USDT -> BTC
        s = s.replace(":USDT", "")
        s = s.replace("/USDT", "")
        s = s.replace("-", "")
        s = s.replace("_", "")
        s = s.replace("PERP", "")
        s = s.replace("USDTPERP", "USDT")

        # BTCUSDT stays BTCUSDT
        if s.endswith("USDT"):
            return s

        # BTC -> BTCUSDT
        if self._re.fullmatch(r"[A-Z0-9]{2,20}", s):
            return s + "USDT"

        return s

    def _parse_symbol_and_tf(self, text: str):
        if not text:
            return None, None

        parts = text.strip().upper().replace("/", " ").replace(":", " ").split()
        tf = None
        symbol = None

        for p in parts:
            p_low = p.lower()
            if p_low in {"5m", "15m", "1h", "4h", "1d"}:
                tf = p_low
            elif not symbol:
                symbol = p

        if not symbol:
            return None, None

        symbol = self._normalize_symbol(symbol)
        return symbol, tf or self.default_tf

    def _extract_symbol(self, text: str):
        if not text:
            return None

        patterns = [
            r"\b([A-Z0-9]{2,20}/USDT:USDT)\b",
            r"\b([A-Z0-9]{2,20}/USDT)\b",
            r"\b([A-Z0-9]{2,20}USDT)\b",
            r"\b(BTC|ETH|SOL|DOGE|OP|ARB|FIL|WIF|LTC|XRP|BNB|ADA|PEPE|LINK|TRX)\b",
        ]
        upper = text.upper()

        for pattern in patterns:
            m = self._re.search(pattern, upper)
            if m:
                return self._normalize_symbol(m.group(1))

        return None

    def _extract_trade_data(self, text: str):
        if not text:
            return None

        upper = text.upper()
        symbol = self._extract_symbol(upper)
        if not symbol:
            return None

        side = "LONG" if "LONG" in upper else ("SHORT" if "SHORT" in upper else None)

        def get_float(pattern):
            m = self._re.search(pattern, text, self._re.IGNORECASE)
            if not m:
                return None
            raw = m.group(1).replace(",", ".")
            try:
                return float(raw)
            except Exception:
                return None

        entry = get_float(r"Entry:\s*\$?([0-9]*\.?[0-9]+)")
        sl = get_float(r"SL:\s*\$?([0-9]*\.?[0-9]+)")
        tp1 = get_float(r"TP1:\s*\$?([0-9]*\.?[0-9]+)")
        tp2 = get_float(r"TP2:\s*\$?([0-9]*\.?[0-9]+)")
        tp3 = get_float(r"TP3:\s*\$?([0-9]*\.?[0-9]+)")

        reason = None
        if "|" in text:
            parts = text.split("|")
            if len(parts) >= 2:
                reason = " | ".join([p.strip() for p in parts[-6:]])

        return {
            "symbol": symbol,
            "side": side or "?",
            "entry": entry,
            "sl": sl,
            "tp1": tp1,
            "tp2": tp2,
            "tp3": tp3,
            "raw": text,
            "reason": reason,
            "updated_at": self._datetime.utcnow().isoformat(),
        }

    # ---------- Utils ----------
    def _split_text(self, text: str, max_len: int = 3900):
        if len(text) <= max_len:
            return [text]

        chunks = []
        buf = []
        size = 0

        for line in text.splitlines(True):
            if size + len(line) > max_len and buf:
                chunks.append("".join(buf))
                buf = [line]
                size = len(line)
            else:
                buf.append(line)
                size += len(line)

        if buf:
            chunks.append("".join(buf))
        return chunks
