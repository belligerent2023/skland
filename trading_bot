# ==================== TELEGRAM NOTIFICATIONS ====================
class TelegramNotifier:
    """
    Drop-in replacement for old TelegramNotifier.
    Совместимость:
        telegram.send(message, urgent=False)  # работает как раньше

    Что добавлено:
    - auto long-polling commands/buttons
    - inline keyboard UI
    - asset analysis for custom symbols
    - chart image sending
    - positions/watchlist memory inside the class
    - no changes required in existing send() calls
    """

    def __init__(self, token: str, chat_id: str):
        import os
        import re
        import json
        import time
        import html
        import queue
        import tempfile
        import threading
        import logging
        from datetime import datetime

        self.token = token
        self.chat_id = str(chat_id)
        self.base_api = f"https://api.telegram.org/bot{token}"
        self.base_file = f"https://api.telegram.org/file/bot{token}"

        self._os = os
        self._re = re
        self._json = json
        self._time = time
        self._html = html
        self._tempfile = tempfile
        self._threading = threading
        self._datetime = datetime
        self._queue = queue

        self.logger = globals().get("logger", logging.getLogger("TelegramNotifier"))
        self.session = requests.Session()

        self.enabled = bool(token and chat_id)
        self.offset = 0
        self.running = False
        self.poll_thread = None

        self.watchlist = set(["BTCUSDT", "ETHUSDT"])
        self.last_analysis = {}      # key: SYMBOL:TF -> analysis dict
        self.positions = {}          # key: SYMBOL -> parsed alert dict
        self.last_messages = {}      # key: arbitrary -> telegram message_id
        self.pending_actions = self._queue.Queue()

        self.default_tf = "1h"
        self.default_limit = 220

        # Optional external handlers if ты потом захочешь подвязать реальные actions
        self.handlers = {
            "custom_command": None,   # fn(text, notifier) -> bool
            "button": None,           # fn(callback_data, notifier) -> bool
        }

        if self.enabled:
            try:
                self._safe_delete_webhook()
                self.start_polling()
            except Exception as e:
                self.logger.error(f"Telegram init error: {e}")

    # ---------- Public API ----------
    def send(self, message: str, urgent: bool = False):
        """Backward-compatible text notification."""
        if not self.enabled:
            return None

        try:
            symbol = self._extract_symbol(message)
            trade = self._extract_trade_data(message)
            if trade:
                self.positions[trade["symbol"]] = trade

            prefix = "[ALERT]" if urgent else "[INFO]"
            text = f"<b>{self._html.escape(prefix)}</b>\n{self._html.escape(str(message))}"

            keyboard = None
            if symbol:
                keyboard = self._keyboard_for_symbol(symbol, include_trade=bool(trade))

            return self._send_message(text, keyboard=keyboard)
        except Exception as e:
            self.logger.error(f"Telegram error: {e}")
            return None

    def send_photo(self, photo_path: str, caption: str = "", keyboard: dict = None):
        """Public helper if you want to send custom chart/photo manually."""
        if not self.enabled:
            return None
        return self._send_photo(photo_path, caption=caption, keyboard=keyboard)

    def start_polling(self):
        """Start long polling thread."""
        if not self.enabled or self.running:
            return

        self.running = True
        self.poll_thread = self._threading.Thread(
            target=self._poll_loop,
            name="TelegramPollingThread",
            daemon=True
        )
        self.poll_thread.start()
        self.logger.info("Telegram polling started")

    def stop(self):
        """Stop polling thread."""
        self.running = False
        self.logger.info("Telegram polling stopped")

    # ---------- HTTP ----------
    def _safe_delete_webhook(self):
        try:
            self._post("deleteWebhook", data={"drop_pending_updates": False}, raise_errors=False)
        except Exception:
            pass

    def _post(self, method: str, data=None, files=None, raise_errors=True):
        url = f"{self.base_api}/{method}"
        try:
            response = self.session.post(url, data=data, files=files, timeout=25)
            payload = response.json() if response.content else {}
            if response.status_code != 200 or not payload.get("ok", False):
                if raise_errors:
                    raise RuntimeError(f"Telegram API {method} failed: {response.text}")
                return None
            return payload.get("result")
        except Exception as e:
            if raise_errors:
                raise
            self.logger.error(f"Telegram API {method} error: {e}")
            return None

    def _get(self, method: str, params=None, raise_errors=True):
        url = f"{self.base_api}/{method}"
        try:
            response = self.session.get(url, params=params, timeout=35)
            payload = response.json() if response.content else {}
            if response.status_code != 200 or not payload.get("ok", False):
                if raise_errors:
                    raise RuntimeError(f"Telegram API {method} failed: {response.text}")
                return None
            return payload.get("result")
        except Exception as e:
            if raise_errors:
                raise
            self.logger.error(f"Telegram API {method} error: {e}")
            return None

    # ---------- Telegram send/edit ----------
    def _send_message(self, text: str, keyboard: dict = None):
        chunks = self._split_text(text, 3900)
        last_result = None

        for i, chunk in enumerate(chunks):
            payload = {
                "chat_id": self.chat_id,
                "text": chunk,
                "parse_mode": "HTML",
                "disable_web_page_preview": True,
            }
            if keyboard and i == len(chunks) - 1:
                payload["reply_markup"] = self._json.dumps(keyboard, ensure_ascii=False)

            last_result = self._post("sendMessage", data=payload, raise_errors=False)

        return last_result

    def _send_photo(self, photo_path: str, caption: str = "", keyboard: dict = None):
        try:
            data = {
                "chat_id": self.chat_id,
                "caption": caption[:1024],
                "parse_mode": "HTML",
            }
            if keyboard:
                data["reply_markup"] = self._json.dumps(keyboard, ensure_ascii=False)

            with open(photo_path, "rb") as f:
                return self._post("sendPhoto", data=data, files={"photo": f}, raise_errors=False)
        except Exception as e:
            self.logger.error(f"Telegram send photo error: {e}")
            return None

    def _edit_message(self, message_id: int, text: str, keyboard: dict = None):
        payload = {
            "chat_id": self.chat_id,
            "message_id": message_id,
            "text": text[:3900],
            "parse_mode": "HTML",
            "disable_web_page_preview": True,
        }
        if keyboard:
            payload["reply_markup"] = self._json.dumps(keyboard, ensure_ascii=False)
        return self._post("editMessageText", data=payload, raise_errors=False)

    def _edit_caption(self, message_id: int, caption: str, keyboard: dict = None):
        payload = {
            "chat_id": self.chat_id,
            "message_id": message_id,
            "caption": caption[:1024],
            "parse_mode": "HTML",
        }
        if keyboard:
            payload["reply_markup"] = self._json.dumps(keyboard, ensure_ascii=False)
        return self._post("editMessageCaption", data=payload, raise_errors=False)

    def _answer_callback(self, callback_query_id: str, text: str = "", alert: bool = False):
        payload = {
            "callback_query_id": callback_query_id,
            "text": text[:180],
            "show_alert": bool(alert),
        }
        return self._post("answerCallbackQuery", data=payload, raise_errors=False)

    def _send_chat_action(self, action: str = "typing"):
        return self._post("sendChatAction", data={"chat_id": self.chat_id, "action": action}, raise_errors=False)

    # ---------- Polling ----------
    def _poll_loop(self):
        while self.running:
            try:
                updates = self._get(
                    "getUpdates",
                    params={
                        "offset": self.offset,
                        "timeout": 25,
                        "allowed_updates": self._json.dumps(["message", "callback_query"])
                    },
                    raise_errors=False
                )

                if not updates:
                    continue

                for upd in updates:
                    self.offset = max(self.offset, upd["update_id"] + 1)
                    self._handle_update(upd)

            except Exception as e:
                self.logger.error(f"Telegram polling error: {e}")
                self._time.sleep(3)

    def _handle_update(self, update: dict):
        try:
            if "message" in update:
                self._handle_message(update["message"])
            elif "callback_query" in update:
                self._handle_callback(update["callback_query"])
        except Exception as e:
            self.logger.error(f"Telegram update handling error: {e}")

    # ---------- Message handling ----------
    def _handle_message(self, message: dict):
        chat = message.get("chat", {})
        chat_id = str(chat.get("id", ""))
        if chat_id != self.chat_id:
            return

        text = (message.get("text") or "").strip()
        if not text:
            return

        # external custom command hook
        try:
            fn = self.handlers.get("custom_command")
            if callable(fn) and fn(text, self) is True:
                return
        except Exception as e:
            self.logger.error(f"Telegram custom command hook error: {e}")

        lower = text.lower()

        if lower in ("/start", "/menu", "menu", "меню", "/help", "help"):
            self._send_main_menu()
            return

        if lower in ("/positions", "positions", "позиции"):
            self._send_positions_menu()
            return

        if lower in ("/watchlist", "watchlist", "вотчлист", "лист"):
            self._send_watchlist_menu()
            return

        if lower.startswith("/add ") or lower.startswith("add "):
            raw = text.split(" ", 1)[1].strip()
            symbol = self._normalize_symbol(raw)
            self.watchlist.add(symbol)
            self._send_message(f"<b>Added:</b> <code>{symbol}</code>", keyboard=self._keyboard_for_symbol(symbol))
            return

        if lower.startswith("/del ") or lower.startswith("/remove ") or lower.startswith("remove "):
            raw = text.split(" ", 1)[1].strip()
            symbol = self._normalize_symbol(raw)
            self.watchlist.discard(symbol)
            self._send_message(f"<b>Removed:</b> <code>{symbol}</code>")
            return

        if lower.startswith("/analyze ") or lower.startswith("analyze ") or lower.startswith("анализ "):
            raw = text.split(" ", 1)[1].strip()
            symbol, tf = self._parse_symbol_and_tf(raw)
            self._send_asset_analysis(symbol, tf=tf)
            return

        # Shortcut: "btc", "btc 4h", "solusdt 1h"
        maybe_symbol, maybe_tf = self._parse_symbol_and_tf(text)
        if maybe_symbol:
            self._send_asset_analysis(maybe_symbol, tf=maybe_tf or self.default_tf)
            return

        self._send_message(
            "<b>Commands</b>\n"
            "/menu\n"
            "/positions\n"
            "/watchlist\n"
            "/add BTC\n"
            "/del BTC\n"
            "/analyze BTC\n"
            "or just send: <code>BTC</code>, <code>ETH 4h</code>, <code>PEPE</code>"
        )

    def _handle_callback(self, callback: dict):
        data = callback.get("data", "")
        cq_id = callback.get("id")
        message = callback.get("message", {}) or {}
        msg_id = message.get("message_id")

        try:
            fn = self.handlers.get("button")
            if callable(fn) and fn(data, self) is True:
                self._answer_callback(cq_id, "Done")
                return
        except Exception as e:
            self.logger.error(f"Telegram button hook error: {e}")

        if data == "m:home":
            self._answer_callback(cq_id, "Menu")
            self._send_main_menu()
            return

        if data == "m:positions":
            self._answer_callback(cq_id, "Positions")
            self._send_positions_menu()
            return

        if data == "m:watch":
            self._answer_callback(cq_id, "Watchlist")
            self._send_watchlist_menu()
            return

        if data == "m:btc":
            self._answer_callback(cq_id, "BTC")
            self._send_asset_analysis("BTCUSDT", tf=self.default_tf)
            return

        if data == "m:eth":
            self._answer_callback(cq_id, "ETH")
            self._send_asset_analysis("ETHUSDT", tf=self.default_tf)
            return

        if data.startswith("a:"):
            # a:BTCUSDT:1h
            parts = data.split(":")
            if len(parts) >= 3:
                symbol = parts[1]
                tf = parts[2]
                self._answer_callback(cq_id, f"{symbol} {tf}")
                self._send_asset_analysis(symbol, tf=tf)
                return

        if data.startswith("w:add:"):
            symbol = data.split(":", 2)[2]
            self.watchlist.add(symbol)
            self._answer_callback(cq_id, f"Added {symbol}")
            self._send_message(f"<b>Added to watchlist:</b> <code>{symbol}</code>")
            return

        if data.startswith("w:del:"):
            symbol = data.split(":", 2)[2]
            self.watchlist.discard(symbol)
            self._answer_callback(cq_id, f"Removed {symbol}")
            self._send_message(f"<b>Removed from watchlist:</b> <code>{symbol}</code>")
            return

        if data.startswith("p:"):
            symbol = data.split(":", 1)[1]
            self._answer_callback(cq_id, symbol)
            self._send_position_card(symbol)
            return

        if data.startswith("refresh:"):
            # refresh:BTCUSDT:1h
            parts = data.split(":")
            if len(parts) >= 3:
                symbol = parts[1]
                tf = parts[2]
                self._answer_callback(cq_id, "Refreshing")
                self._send_asset_analysis(symbol, tf=tf)
                return

        if data.startswith("noop"):
            self._answer_callback(cq_id, "Info")
            return

        self._answer_callback(cq_id, "Unknown action")

