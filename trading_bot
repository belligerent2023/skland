    def _render_chart(self, symbol: str, tf: str, df, resistance: float, support: float):
        try:
            import matplotlib # type: ignore
            matplotlib.use("Agg")
            import matplotlib.pyplot as plt # type: ignore

            tmp = self._tempfile.NamedTemporaryFile(delete=False, suffix=".png")
            path = tmp.name
            tmp.close()

            fig = plt.figure(figsize=(14, 8))
            ax1 = plt.subplot(2, 1, 1)
            ax2 = plt.subplot(2, 1, 2, sharex=ax1)

            x = range(len(df))
            ax1.plot(x, df["close"], label="Close", linewidth=1.6)
            ax1.plot(x, df["ema20"], label="EMA20", linewidth=1.1)
            ax1.plot(x, df["ema50"], label="EMA50", linewidth=1.1)
            ax1.plot(x, df["ema200"], label="EMA200", linewidth=1.1)

            ax1.axhline(resistance, linestyle="--", linewidth=1, alpha=0.7, label="Resistance")
            ax1.axhline(support, linestyle="--", linewidth=1, alpha=0.7, label="Support")

            ax1.set_title(f"{symbol} {tf}")
            ax1.legend(loc="upper left")
            ax1.grid(alpha=0.25)

            ax2.plot(x, df["rsi14"], label="RSI14", linewidth=1.2, color="purple")
