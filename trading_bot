    def get_positions(self) -> List[Dict]:
        """Get open positions with CORRECT contract calculation"""
        try:
            positions = self.exchange.fetch_positions()
            
            active_positions = []
            for p in positions:
                contracts = float(p.get('contracts', 0))
                
                if contracts > 0:
                    symbol = p['symbol']
                    
                    specs = self._get_contract_specs_internal(symbol)
                    contract_size = specs.get('contract_size', 1)
                    
                    position_size_base = contracts * contract_size
                    
                    logger.info(f"  POSITION: {symbol}")
                    logger.info(f"   Contracts: {contracts}")
                    logger.info(f"   Contract size: {contract_size}")
                    logger.info(f"   Position size: {position_size_base} {symbol.split('/')[0]}")
                    
                    p['position_size_base'] = position_size_base
                    
                    active_positions.append(p)
            
            return active_positions
        except Exception as e:
            logger.error(f"Positions fetch error: {e}")
            return []
        
