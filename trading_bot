            self._send_message(f"<b>Analysis error:</b> {self._html.escape(str(e))}")

    def _build_analysis(self, symbol: str, tf: str = "1h", limit: int = 220):
        try:
            import math
            import pandas as pd
        except Exception:
            pd = None

        klines = self._fetch_klines(symbol, tf, limit)
        if not klines:
            return None

        if pd is None:
            return self._build_analysis_no_pandas(symbol, tf, klines)

        df = pd.DataFrame(klines, columns=[
            "open_time", "open", "high", "low", "close", "volume", "close_time"
        ])
        for col in ["open", "high", "low", "close", "volume"]:
            df[col] = pd.to_numeric(df[col], errors="coerce")

        df["ema20"] = df["close"].ewm(span=20, adjust=False).mean()
        df["ema50"] = df["close"].ewm(span=50, adjust=False).mean()
        df["ema200"] = df["close"].ewm(span=200, adjust=False).mean()

        delta = df["close"].diff()
        gain = delta.clip(lower=0).rolling(14).mean()
        loss = (-delta.clip(upper=0)).rolling(14).mean()
        rs = gain / loss.replace(0, 1e-9)
        df["rsi14"] = 100 - (100 / (1 + rs))

        last = df.iloc[-1]
        prev = df.iloc[-2]

        close = float(last["close"])
        ema20 = float(last["ema20"])
        ema50 = float(last["ema50"])
        ema200 = float(last["ema200"])
        rsi = float(last["rsi14"]) if pd.notna(last["rsi14"]) else 50.0
        vol_ratio = float(last["volume"] / max(df["volume"].tail(20).mean(), 1e-9))

        swing_high = float(df["high"].tail(50).max())
        swing_low = float(df["low"].tail(50).min())

        dist_high = ((swing_high - close) / close) * 100
        dist_low = ((close - swing_low) / close) * 100

        if close > ema20 > ema50 > ema200:
            trend = "BULLISH"
        elif close < ema20 < ema50 < ema200:
            trend = "BEARISH"
        else:
            trend = "MIXED"

        if trend == "BULLISH" and rsi > 70:
            verdict = "BULLISH but extended"
        elif trend == "BEARISH" and rsi < 30:
            verdict = "BEARISH but stretched"
        elif trend == "BULLISH":
            verdict = "BULLISH"
        elif trend == "BEARISH":
            verdict = "BEARISH"
        else:
            verdict = "NEUTRAL / MIXED"

        notes = []
        notes.append(f"Trend: {trend}")
        notes.append(f"Close vs EMA20/50/200: {close:.6f} / {ema20:.6f} / {ema50:.6f} / {ema200:.6f}")
        notes.append(f"RSI14: {rsi:.1f}")
        notes.append(f"Volume ratio: x{vol_ratio:.2f}")
        notes.append(f"Resistance: {swing_high:.6f} ({dist_high:.2f}%)")
        notes.append(f"Support: {swing_low:.6f} ({dist_low:.2f}%)")

        if trend == "BULLISH":
            setup = f"Look for pullbacks above EMA20/EMA50. Invalidation below {swing_low:.6f}."
        elif trend == "BEARISH":
            setup = f"Look for bounces into EMA20/EMA50. Invalidation above {swing_high:.6f}."
        else:
            setup = f"Market is mixed. Better wait for break of {swing_high:.6f} or {swing_low:.6f}."

        chart_path = self._render_chart(symbol, tf, df, swing_high, swing_low)

        return {
            "symbol": symbol,
            "tf": tf,
            "close": close,
            "ema20": ema20,
            "ema50": ema50,
            "ema200": ema200,
            "rsi14": rsi,
            "vol_ratio": vol_ratio,
            "trend": trend,
            "verdict": verdict,
            "support": swing_low,
            "resistance": swing_high,
            "setup": setup,
            "notes": notes,
            "chart_path": chart_path,
        }

    def _build_analysis_no_pandas(self, symbol: str, tf: str, klines: list):
        closes = [float(x[4]) for x in klines]
        highs = [float(x[2]) for x in klines]
        lows = [float(x[3]) for x in klines]
        volumes = [float(x[5]) for x in klines]

        def ema(values, span):
            alpha = 2 / (span + 1)
            out = [values[0]]
            for v in values[1:]:
                out.append(alpha * v + (1 - alpha) * out[-1])
            return out

        def rsi(values, period=14):
            if len(values) < period + 1:
                return 50.0
            gains, losses = [], []
            for i in range(1, len(values)):
                diff = values[i] - values[i - 1]
                gains.append(max(diff, 0))
                losses.append(max(-diff, 0))
            avg_gain = sum(gains[-period:]) / period
            avg_loss = sum(losses[-period:]) / period
            if avg_loss == 0:
                return 100.0
            rs = avg_gain / avg_loss
            return 100 - (100 / (1 + rs))

        ema20 = ema(closes, 20)[-1]
        ema50 = ema(closes, 50)[-1]
        ema200 = ema(closes, 200)[-1]
        close = closes[-1]
        rsi14 = rsi(closes)
        vol_ma = sum(volumes[-20:]) / max(len(volumes[-20:]), 1)
        vol_ratio = volumes[-1] / max(vol_ma, 1e-9)
        swing_high = max(highs[-50:])
        swing_low = min(lows[-50:])

        if close > ema20 > ema50 > ema200:
            trend = "BULLISH"
        elif close < ema20 < ema50 < ema200:
            trend = "BEARISH"
        else:
            trend = "MIXED"

        if trend == "BULLISH":
            verdict = "BULLISH"
            setup = f"Look for pullbacks above EMA20/EMA50. Invalidation below {swing_low:.6f}."
        elif trend == "BEARISH":
            verdict = "BEARISH"
            setup = f"Look for bounces into EMA20/EMA50. Invalidation above {swing_high:.6f}."
        else:
            verdict = "NEUTRAL / MIXED"
            setup = f"Wait for break of {swing_high:.6f} or {swing_low:.6f}."

        return {
            "symbol": symbol,
            "tf": tf,
            "close": close,
            "ema20": ema20,
            "ema50": ema50,
            "ema200": ema200,
            "rsi14": rsi14,
            "vol_ratio": vol_ratio,
            "trend": trend,
            "verdict": verdict,
            "support": swing_low,
            "resistance": swing_high,
            "setup": setup,
            "notes": [
                f"Trend: {trend}",
                f"Close: {close:.6f}",
                f"EMA20/50/200: {ema20:.6f}/{ema50:.6f}/{ema200:.6f}",
                f"RSI14: {rsi14:.1f}",
                f"Volume ratio: x{vol_ratio:.2f}",
            ],
            "chart_path": None,
        }

    def _format_analysis_caption(self, a: dict):
        lines = [
            f"<b>{a['symbol']} {a['tf']} analysis</b>",
            f"<b>Verdict:</b> {self._html.escape(a['verdict'])}",
