class ExchangeManager:
    def __init__(self):
        self.exchange = ccxt.bingx({
            'apiKey': Config.OKX_API_KEY,
            'secret': Config.OKX_API_SECRET,
            'adjustForTimeDifference': True,
            'enableRateLimit': True,
            'options': {
                'defaultType': 'swap',
                'recvWindow': '10000',
            },
        })
        self._fix_timestamp()

    def _fix_timestamp(self):
        """Патчим nonce() напрямую — единственный надёжный способ для BingX"""
        try:
            server_time = self.exchange.fetch_time()
            local_time  = int(time.time() * 1000)
            offset = server_time - local_time   # насколько сервер впереди локального времени
            
            logger.info(f"BingX offset: {offset:+d}ms (server ahead of local)")
            
            # Переопределяем nonce() чтобы возвращал серверное время
            exchange_ref = self.exchange
            def corrected_nonce():
                return int(time.time() * 1000) + offset
            
            exchange_ref.nonce = corrected_nonce  # патчим instance-метод напрямую
            
            # Тест — проверяем что теперь работает
            test_time = self.exchange.nonce()
            logger.info(f"Nonce after patch: {test_time} | Expected ~{server_time}")
            
        except Exception as e:
            logger.error(f"Time fix failed: {e}")
            
    def get_balance(self) -> float:
        """Get USDT balance - returns total_equity"""
        try:
            balance = self.exchange.fetch_balance()
            
            total_equity = float(balance['USDT'].get('total', 0))
            free_balance = float(balance['USDT'].get('free', 0))
            used_margin = total_equity - free_balance
            
            logger.info(f" BALANCE DETAILS:")
            logger.info(f"   Total Equity: ${total_equity:.2f}")
            logger.info(f"   Free (Available): ${free_balance:.2f}")
            logger.info(f"   Used in positions: ${used_margin:.2f}")
            
            return total_equity
        except Exception as e:
            logger.error(f"Balance fetch error: {e}")
            return 0.0

    def get_free_balance(self) -> float:
        """ Получить РЕАЛЬНЫЙ свободный баланс с учетом позиций"""
        try:
            balance = self.exchange.fetch_balance()
            free_balance = float(balance['USDT'].get('free', 0))
            
            #  КРИТИЧНО: Получаем открытые позиции для расчета реальной маржи
            positions = self.exchange.fetch_positions()
            
            # Считаем РЕАЛЬНО используемую маржу в позициях
            total_position_margin = 0.0
            for p in positions:
                contracts = float(p.get('contracts', 0))
                if contracts > 0:
                    # Initial margin каждой позиции
                    initial_margin = float(p.get('initialMargin', 0))
                    total_position_margin += initial_margin
                    
                    symbol = p.get('symbol', 'Unknown')
                    logger.info(f" Position margin: {symbol} = ${initial_margin:.2f}")
            
            #  РЕАЛЬНЫЙ свободный баланс = free - дополнительный резерв (10%)
            # OKX резервирует дополнительно для комиссий и ликвидации
            safety_buffer = total_position_margin * 0.10  # 10% от маржи позиций
            real_free_balance = free_balance - safety_buffer
            
            logger.info(f" REAL FREE BALANCE:")
            logger.info(f"   CCXT Free: ${free_balance:.2f}")
            logger.info(f"   Position margin: ${total_position_margin:.2f}")
            logger.info(f"   Safety buffer (10%): ${safety_buffer:.2f}")
            logger.info(f"   Real available: ${real_free_balance:.2f}")
            
            # Минимум - не может быть отрицательным
            return max(0, real_free_balance)
            
        except Exception as e:
            logger.error(f"Free balance fetch error: {e}")
            return 0.0

    def _get_contract_specs_internal(self, symbol: str) -> Dict:
