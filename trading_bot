    def _send_position_card(self, symbol: str):
        p = self.positions.get(symbol)
        if not p:
            self._send_message(f"<b>No stored card for</b> <code>{symbol}</code>")
            return

        text = [
            f"<b>{symbol} {p.get('side', '?')}</b>",
            f"Entry: <code>{p.get('entry', '?')}</code>",
            f"SL: <code>{p.get('sl', '?')}</code>",
        ]

        if p.get("tp1") is not None:
            text.append(f"TP1: <code>{p.get('tp1')}</code>")
        if p.get("tp2") is not None:
            text.append(f"TP2: <code>{p.get('tp2')}</code>")
        if p.get("tp3") is not None:
            text.append(f"TP3: <code>{p.get('tp3')}</code>")
        if p.get("reason"):
            text.append("")
            text.append(f"<b>Reason</b>\n{self._html.escape(p['reason'])[:1500]}")

        kb = self._keyboard_for_symbol(symbol, include_trade=True)
        self._send_message("\n".join(text), keyboard=kb)

    def _keyboard_for_symbol(self, symbol: str, include_trade: bool = False):
        rows = [
            [
                {"text": "1h", "callback_data": f"a:{symbol}:1h"},
                {"text": "4h", "callback_data": f"a:{symbol}:4h"},
                {"text": "1d", "callback_data": f"a:{symbol}:1d"},
            ],
            [
                {"text": "Refresh", "callback_data": f"refresh:{symbol}:{self.default_tf}"},
                {"text": "Add WL", "callback_data": f"w:add:{symbol}"},
            ],
        ]
        if include_trade:
            rows.append([{"text": "Position", "callback_data": f"p:{symbol}"}])
        rows.append([{"text": "Home", "callback_data": "m:home"}])
        return {"inline_keyboard": rows}

    # ---------- Analysis ----------
    def _send_asset_analysis(self, symbol: str, tf: str = "1h"):
        try:
            symbol = self._normalize_symbol(symbol)
            tf = self._normalize_tf(tf)

            self._send_chat_action("upload_photo")

